@{
    ViewBag.Title = "Đổi mật khẩu";
}

<style>
    /* nền */
    .reset-wrapper {
        height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    }

    /* box */
    .reset-box {
        width: 100%;
        max-width: 400px;
        background: #fff;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        animation: fadeUp 0.4s ease;
    }

    /* animation */
    keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* title */
    .reset-title {
        text-align: center;
        font-weight: bold;
        font-size: 26px;
        margin-bottom: 10px;
    }

    /* desc */
    .reset-desc {
        text-align: center;
        color: #777;
        margin-bottom: 25px;
    }

    /* input */
    .reset-input {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        background: #f9fafb;
        transition: 0.25s;
    }

        .reset-input:focus {
            border-color: #ee4d2d;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(238,77,45,0.15);
            outline: none;
        }

    /* button */
    .reset-btn {
        width: 100%;
        margin-top: 15px;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #ee4d2d, #ff7337);
        color: white;
        font-weight: 600;
        transition: 0.25s;
    }

        .reset-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(238,77,45,0.3);
        }

    /* success */
    .reset-success {
        margin-top: 10px;
        color: green;
        text-align: center;
        font-size: 14px;
    }
</style>

<div class="reset-wrapper">
    <div class="reset-box">

        <h2 class="reset-title">Đổi mật khẩu</h2>
        <p class="reset-desc">Nhập mật khẩu mới của bạn</p>

        <form method="post">
            <input type="password" name="matKhauMoi" class="reset-input" placeholder="Mật khẩu mới" required />
            <button type="submit" class="reset-btn">Đổi mật khẩu</button>
        </form>

        @if (ViewBag.Success != null)
        {
            <p class="reset-success">@ViewBag.Success</p>
        }

    </div>
</div>