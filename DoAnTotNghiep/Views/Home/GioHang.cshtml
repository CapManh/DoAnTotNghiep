@model IEnumerable<DoAnTotNghiep.Models.GioHang>
@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="@Url.Content("~/Content/GioHang.css")" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container my-5">
    @if (Model != null && Model.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card p-3 shadow-sm">
                    <table class="table align-middle" id="cartTable">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="selectAll"></th>
                                <th>SẢN PHẨM</th>
                                <th>GIÁ</th>
                                <th>SỐ LƯỢNG</th>
                                <th>TỔNG</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var gia = item.SanPham?.Gia ?? 0;
                                var soLuong = item.SoLuong ?? 1;
                                var tonKho = item.SanPham?.ChiTietSanPhams?.FirstOrDefault()?.SoLuongTon ?? 0;

                                <tr data-stock="@tonKho" data-product-name="@item.SanPham.TenSanPham">
                                    <td><input type="checkbox" class="item-checkbox" value="@item.MaSanPham"></td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@Url.Content(item.SanPham.AnhChinh ?? "")" style="width:60px;height:60px;object-fit:cover">
                                            <div class="ms-3"><h6>@item.SanPham.TenSanPham</h6></div>
                                        </div>
                                    </td>
                                    <td class="price" data-price="@gia">@string.Format("{0:N0}", gia) ₫</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <button class="btn btn-outline-secondary btn-sm minus">-</button>
                                            <input type="number" class="form-control text-center mx-2 qty-input" value="@soLuong" min="1" style="width:70px">
                                            <button class="btn btn-outline-secondary btn-sm plus">+</button>
                                        </div>
                                    </td>
                                    <td class="total">@string.Format("{0:N0}", gia * soLuong) ₫</td>
                                    <td>
                                        <button onclick="deleteItem(@item.MaSanPham)" class="btn btn-danger btn-sm">Xóa</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card p-4 shadow-sm sticky-top">
                    <h5>Tóm tắt</h5>
                    <div class="d-flex justify-content-between">
                        <span>Đã chọn:</span>
                        <span id="selectedCount">0</span>
                    </div>
                    <div class="d-flex justify-content-between mt-3">
                        <span>Tổng tiền:</span>
                        <span id="totalAmount">0 ₫</span>
                    </div>
                    <button id="btnThanhToan" class="btn btn-warning w-100 mt-4 fw-bold py-3">
                        THANH TOÁN NGAY
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h4>Giỏ hàng của bạn đang trống</h4>
            <a href="/Home/sanpham1" class="btn btn-primary mt-3">Tiếp tục mua sắm</a>
        </div>
    }
</div>
<script>
    // ==================== CẬP NHẬT TỔNG TIỀN & SỐ LƯỢNG ĐÃ CHỌN ====================
    function updateCart() {
        let total = 0;
        let count = 0;

        document.querySelectorAll('#cartTable tbody tr').forEach(row => {
            const checkbox = row.querySelector('.item-checkbox');
            if (!checkbox) return;

            const priceEl = row.querySelector('.price');
            const qtyInput = row.querySelector('.qty-input');

            const price = parseFloat(priceEl ? priceEl.dataset.price : 0) || 0;
            let qty = parseInt(qtyInput ? qtyInput.value : 1) || 1;

            // Đảm bảo số lượng không nhỏ hơn 1
            if (qty < 1) {
                qty = 1;
                if (qtyInput) qtyInput.value = 1;
            }

            // Cập nhật cột tổng của từng dòng
            const lineTotalEl = row.querySelector('.total');
            if (lineTotalEl) {
                lineTotalEl.innerText = (price * qty).toLocaleString('vi-VN') + " ₫";
            }

            // Nếu checkbox được chọn → cộng vào tổng tiền
            if (checkbox.checked) {
                total += price * qty;
                count++;
            }
        });

        // Cập nhật tổng tiền và số lượng đã chọn
        document.getElementById('totalAmount').innerText = total.toLocaleString('vi-VN') + " ₫";
        document.getElementById('selectedCount').innerText = count;
    }

    // ==================== CẬP NHẬT SỐ LƯỢNG VÀO DATABASE ====================
    async function updateQuantityToDB(maSanPham, soLuong) {
        if (!maSanPham) return false;

        try {
            const response = await fetch('/Home/CapNhatSoLuongGioHang', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ maSanPham: maSanPham, soLuong: soLuong })
            });

            const result = await response.json();
            return result.success === true;
        } catch (error) {
            console.error('Lỗi cập nhật số lượng:', error);
            return false;
        }
    }

    // ==================== XỬ LÝ NÚT + / - ====================
    document.addEventListener('click', async function (e) {
        if (e.target.classList.contains('plus') || e.target.classList.contains('minus')) {
            const parent = e.target.parentElement;
            const input = parent.querySelector('.qty-input');
            if (!input) return;

            let value = parseInt(input.value) || 1;
            const maSanPham = parseInt(input.dataset.maSanPham) || parseInt(input.closest('tr').querySelector('.item-checkbox').value);

            if (e.target.classList.contains('plus')) {
                value++;
            } else if (value > 1) {
                value--;
            }

            input.value = value;

            // Cập nhật vào DB
            if (maSanPham) {
                await updateQuantityToDB(maSanPham, value);
            }

            updateCart();
        }
    });

    // ==================== Nhập số lượng trực tiếp ====================
    document.addEventListener('change', async function (e) {
        if (e.target.classList.contains('qty-input')) {
            let value = parseInt(e.target.value) || 1;
            if (value < 1) value = 1;
            e.target.value = value;

            const maSanPham = parseInt(e.target.dataset.maSanPham) ||
                parseInt(e.target.closest('tr').querySelector('.item-checkbox').value);

            if (maSanPham) {
                await updateQuantityToDB(maSanPham, value);
            }

            updateCart();
        }
    });

    // ==================== Chọn tất cả ====================
    document.getElementById('selectAll').addEventListener('change', function () {
        document.querySelectorAll('.item-checkbox').forEach(cb => {
            cb.checked = this.checked;
        });
        updateCart();
    });

    // ==================== Checkbox đơn lẻ ====================
    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('item-checkbox')) {
            updateCart();
        }
    });

    // ==================== NÚT THANH TOÁN ====================
    document.getElementById('btnThanhToan').addEventListener('click', async function () {
        const selected = document.querySelectorAll('.item-checkbox:checked');
        if (selected.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'Chưa chọn sản phẩm',
                text: 'Vui lòng chọn ít nhất một sản phẩm!'
            });
            return;
        }

        // Kiểm tra tồn kho
        let hasError = false;
        let errorList = [];
        selected.forEach(cb => {
            const row = cb.closest('tr');
            const tenSP = row.getAttribute('data-product-name') || "Sản phẩm";
            const qty = parseInt(row.querySelector('.qty-input').value) || 1;
            const stock = parseInt(row.getAttribute('data-stock')) || 0;

            if (qty > stock) {
                hasError = true;
                errorList.push(`• ${tenSP}: chỉ còn ${stock} (bạn chọn ${qty})`);
            }
        });

        if (hasError) {
            Swal.fire({
                icon: 'error',
                title: 'Không đủ tồn kho!',
                html: errorList.join('<br>') + '<br><br>Vui lòng giảm số lượng trước khi thanh toán.',
                confirmButtonText: 'Đã hiểu'
            });
            return;
        }

        // Chuyển sang trang Thanh toán
        const ids = Array.from(selected).map(x => x.value).join(',');
        window.location.href = '/Home/ThanhToan?ids=' + encodeURIComponent(ids);
    });

    // ==================== XÓA SẢN PHẨM ====================
    function deleteItem(id) {
        Swal.fire({
            title: 'Xóa sản phẩm này?',
            text: "Bạn có chắc chắn muốn xóa?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Có, xóa',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '/Home/XoaGioHang',
                    type: 'POST',
                    data: { id: id },
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: response.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Lỗi', response.message || 'Xóa thất bại!', 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi', 'Không thể kết nối server!', 'error');
                    }
                });
            }
        });
    }

    // ==================== KHỞI TẠO KHI LOAD TRANG ====================
    window.onload = function () {
        // Thêm data-ma-san-pham vào input số lượng để dễ lấy
        document.querySelectorAll('.qty-input').forEach(input => {
            const row = input.closest('tr');
            const checkbox = row.querySelector('.item-checkbox');
            if (checkbox) {
                input.dataset.maSanPham = checkbox.value;
            }
        });

        updateCart();
    };
</script>