<style>
    .success-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff6a00, #ee0979, #00c9ff);
        background-size: 300% 300%;
        animation: gradientMove 6s ease infinite;
    }

    keyframes gradientMove {
        0%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    100% {
        background-position: 0% 50%;
    }

    }

    .success-card {
        background: #fff;
        padding: 50px 40px;
        border-radius: 25px;
        text-align: center;
        width: 420px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.3);
        animation: popUp 0.6s ease;
        position: relative;
        overflow: hidden;
    }


    keyframes popUp {
        from

    {
        transform: scale(0.7);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }

    /* ICON */
    .icon-check {
        width: 90px;
        height: 90px;
        background: linear-gradient(45deg, #00c853, #64dd17);
        color: #fff;
        font-size: 45px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 auto 20px;
        box-shadow: 0 10px 30px rgba(0,200,83,0.6);
        animation: bounce 1s ease;
    }

    keyframes bounce {
        0%

    {
        transform: scale(0);
    }

    60% {
        transform: scale(1.2);
    }

    100% {
        transform: scale(1);
    }

    }

    /* TEXT */
    .success-card h2 {
        font-weight: bold;
        margin-bottom: 10px;
    }

    .sub-text {
        color: #666;
        margin-bottom: 25px;
    }

    /* INFO BOX */
    .order-info {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 15px;
        margin-bottom: 25px;
    }

        .order-info div {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

    .price {
        color: #ff1744;
        font-size: 18px;
    }

    /* BUTTON */
    .btn-home {
        display: inline-block;
        width: 100%;
        padding: 14px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(45deg, #ff6a00, #ee0979);
        transition: 0.3s;
    }

        .btn-home:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

    /* CONFETTI */
    .success-card::before {
        content: "";
        position: absolute;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.4) 2px, transparent 2px);
        background-size: 30px 30px;
        animation: sparkle 6s linear infinite;
        top: -50%;
        left: -50%;
        pointer-events: none;
    }

    keyframes sparkle {
        0%

    {
        transform: translate(0,0);
    }

    100% {
        transform: translate(50px, 50px);
    }
    }
</style>

<div class="success-container">

    <div class="success-card">

        <div class="icon-check">
            ✔
        </div>

        <h2>🎉 Đặt hàng thành công</h2>
        <p class="sub-text">
            Cảm ơn bạn đã mua hàng 💖<br>
            Đơn hàng sẽ được giao sớm nhất 🚚
        </p>

        <div class="order-info">
            <div>
                <span>Mã đơn hàng</span>
                <b>#@ViewBag.MaDonHang</b>
            </div>

            <div>
                <span>Tổng tiền</span>
                <b class="price">@ViewBag.TongTien.ToString("N0") ₫</b>
            </div>
        </div>

        <a href="/Home/TrangChu" class="btn-home">
            🏠 Về trang chủ
        </a>

    </div>

</div>