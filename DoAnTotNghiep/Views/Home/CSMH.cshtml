@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Banner Slider</title>
    <style>
        .policy-header {
            height: 250px;
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
                        url('/AnhWeb/PHÒNG KHÁCH.jpg') no-repeat center center;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .policy-header h1 {
            font-size: 2.8rem;
            letter-spacing: -1px;
        }
        .policy-card {
            border: 1px solid #eee;
            line-height: 1.8;
        }

        .policy-item h4 {
            color: #333;
            font-size: 1.25rem;
            margin-bottom: 15px;
        }

        .policy-item i {
            color: #f39200;
        }

        .policy-item p {
            font-size: 1.1rem;
            color: #555 !important;
            padding-left: 32px;
        }

        .hover-opacity-75:hover {
            opacity: 0.75 !important;
            transition: 0.3s;
        }
    </style>
</head>
<body>
    <section class="policy-header">
        <div class="container text-center text-white">
            <h1 class="fw-bold">Chính sách mua hàng</h1>
            <p>
                <a href="/" class="text-white text-decoration-none opacity-100 hover-opacity-75">Trang chủ</a>
                / <span class="opacity-75">Chính sách mua hàng</span>
            </p>
        </div>
    </section>

    <section class="policy-content py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="policy-card p-4 p-md-5 bg-white shadow-sm rounded-4">
                        <h2 class="fw-bold mb-4">Quy định chung</h2>
                        <p class="fs-5 text-muted">
                            Chào mừng bạn đến với Nội thất Mạnh Tuân. Khi bạn thực hiện mua sắm tại cửa hàng hoặc qua website của chúng tôi, vui lòng đọc kỹ các chính sách dưới đây để đảm bảo quyền lợi của mình.
                        </p>

                        <div class="policy-item mt-5">
                            <h4 class="fw-bold"><i class="bi bi-1-circle-fill me-2"></i> Quy trình đặt hàng</h4>
                            <p class="text-muted">Khách hàng có thể đặt hàng trực tiếp qua website, hotline hoặc tại showroom. Sau khi nhận được đơn hàng, nhân viên sẽ liên hệ xác nhận thông tin trong vòng 24h.</p>
                        </div>

                        <div class="policy-item mt-4">
                            <h4 class="fw-bold"><i class="bi bi-2-circle-fill me-2"></i> Hình thức thanh toán</h4>
                            <p class="text-muted">Chúng tôi chấp nhận các hình thức thanh toán linh hoạt: Tiền mặt, chuyển khoản ngân hàng, hoặc thanh toán qua thẻ tín dụng/mã QR.</p>
                        </div>

                        <div class="policy-item mt-4">
                            <h4 class="fw-bold"><i class="bi bi-3-circle-fill me-2"></i> Hủy đơn hàng</h4>
                            <p class="text-muted">Khách hàng có quyền hủy đơn hàng trước khi sản phẩm được bàn giao cho đơn vị vận chuyển. Vui lòng liên hệ hotline sớm nhất có thể.</p>
                        </div>

                        <div class="policy-item mt-4">
                            <h4 class="fw-bold"><i class="bi bi-info-circle-fill me-2"></i> Lưu ý về sản phẩm</h4>
                            <p class="text-muted italic"><em>* Màu sắc sản phẩm trên hình ảnh có thể chênh lệch 5-10% so với thực tế do điều kiện ánh sáng và màn hình hiển thị.</em></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</body>
</html>
