@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .news-header {
        height: 250px;
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/AnhWeb/PHÒNG KHÁCH.jpg') no-repeat center center;
        background-size: cover;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .news-item-card {
        border: none;
        background: transparent;
        margin-bottom: 30px;
    }

    .news-thumb-wrapper {
        overflow: hidden;
        border-radius: 20px;
        aspect-ratio: 16 / 10;
    }
    .news-thumb-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .news-item-card:hover .news-thumb-wrapper img {
        transform: scale(1.1);
    }

    .news-content {
        padding: 15px 0;
    }

    .news-title {
        font-size: 1.15rem;
        font-weight: 700;
        line-height: 1.4;
        color: #000;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 8px;
        transition: color 0.3s;
    }
    .news-title:hover {
        color: #f39200;
    }
    .news-date {
        font-size: 0.85rem;
        color: #888;
        margin-bottom: 10px;
    }
    .news-desc {
        font-size: 0.9rem;
        color: #555;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<section class="news-header mb-5">
    <div class="container text-center text-white">
        <h1 class="fw-bold">Tin tức</h1>
        <p>
            <a href="/" class="text-white text-decoration-none opacity-100">Trang chủ</a>
            / <span class="opacity-75">Tin tức</span>
        </p>
    </div>
</section>

<div class="container pb-5">
    <div class="row">

        <div class="col-md-6 col-lg-4">
            <div class="news-item-card">
                <div class="news-thumb-wrapper shadow-sm">
                    <a href="#"><img src="~/AnhWeb/tin-tuc-1.jpg" alt="Title"></a>
                </div>
                <div class="news-content">
                    <a href="#" class="news-title">10 thiết kế nội thất kỳ quặc khiến gia chủ phát hoảng</a>
                    <div class="news-date">20/10/2025</div>
                    <p class="news-desc">Những cách thiết kế kỳ lạ này khiến người ta phải đặt dấu chấm hỏi về ý tưởng của kiến trúc sư. Lorem Ipsum chỉ đơn giản là một...</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="news-item-card">
                <div class="news-thumb-wrapper shadow-sm">
                    <a href="#"><img src="~/AnhWeb/tin-tuc-2.jpg" alt="Title"></a>
                </div>
                <div class="news-content">
                    <a href="#" class="news-title">Khai mạc Triển lãm nội thất – xây dựng Việt Nam VIBE 2025: Tương lai của không gian sống</a>
                    <div class="news-date">20/10/2025</div>
                    <p class="news-desc">Với chủ đề "Next in Space – Tương lai của không gian sống", VIBE 2025 quy tụ 150 doanh nghiệp, hơn 550 gian hàng...</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="news-item-card">
                <div class="news-thumb-wrapper shadow-sm">
                    <a href="#"><img src="~/AnhWeb/tin-tuc-3.jpg" alt="Title"></a>
                </div>
                <div class="news-content">
                    <a href="#" class="news-title">Ngành nội thất và xây dựng mỹ ứng phó với mức thuế mới</a>
                    <div class="news-date">20/10/2025</div>
                    <p class="news-desc">Với những chính sách kinh tế mới, các doanh nghiệp nội thất đang phải tìm cách tối ưu hóa chi phí sản xuất và vận hành...</p>
                </div>
            </div>
        </div>

    </div>
</div>