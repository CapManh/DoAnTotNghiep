@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section PageCss {
    <link href="~/Content/GioiThieu.css" rel="stylesheet" />
}
<section class="about-header">
    <div class="container text-center text-white">
        <h1 class="fw-bold">Giới thiệu</h1>
        <p class="small">Trang chủ / <span class="opacity-75">Giới thiệu</span></p>
    </div>
</section>

<section class="about-main-content py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h6 class="text-danger fw-bold mb-1">LOGO</h6>
            <p class="small text-uppercase tracking-widest text-muted" style="letter-spacing: 2px;">
                TRỞ NÊN TỐT HƠN MỖI NGÀY CÙNG NHAU
            </p>
            <h2 class="display-6 fw-bold text-uppercase">Tương lai của nội thất</h2>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <div class="about-hero-img">
                    <img src="~/AnhWeb/about-hero.jpg" alt="Showroom" class="img-fluid rounded-4 shadow-sm" />
                </div>
            </div>
        </div>

        <div class="row about-text-details">
            <div class="col-md-4">
                <h3 class="fw-bold h4">Chất lượng thiết kế sáng tạo đơn giản</h3>
            </div>
            <div class="col-md-4">
                <p class="small text-muted">
                    Trở thành một tập đoàn uy tín hàng đầu khu vực trong lĩnh vực phân phối nội thất văn phòng cao cấp, hiện đại. Với phương châm kinh doanh đặt lợi ích của cộng đồng lên trên hết, 100% các sản phẩm nội thất văn phòng do Nội thất Mạnh Tuân cung cấp đều có nguồn gốc xuất xứ rõ ràng...
                </p>
            </div>
            <div class="col-md-4">
                <p class="small text-muted">
                    Nội thất Mạnh Tuân không ngừng cập nhật xu hướng, xây dựng hệ sinh thái các sản phẩm nội thất văn phòng đẳng cấp, nhằm tạo nên các không gian làm việc tiện nghi, thoải mái và khơi dậy nguồn năng lực tích cực cho người lao động trí thức.
                </p>
            </div>
        </div>
    </div>
</section>
