@model DoAnTotNghiep.Models.SanPham
@using DoAnTotNghiep.Models

@{
    ViewBag.Title = "Chi Tiết Sản Phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var chiTiet = ViewBag.ChiTietSanPham as ChiTietSanPham;
    var danhGias = ViewBag.DanhGias as List<DanhGia> ?? new List<DanhGia>();

    double avgRating = ViewBag.AverageRating ?? 0.0;
    int reviewCount = ViewBag.ReviewCount ?? 0;
    int soldCount = ViewBag.SoldCount ?? 0;
    int soLuongTon = ViewBag.SoLuongTon ?? 0;
    bool conHang = soLuongTon > 0;
    bool duocDanhGia = ViewBag.DuocDanhGia ?? false; // ✅ THÊM
}

<link rel="stylesheet" href="@Url.Content("~/Content/chitietsanpham.css")" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="container mt-5">
    <div class="row bg-white p-4 rounded shadow-sm">
        <!-- LEFT: IMAGE -->
        <div class="col-lg-6">
            <div class="text-center mb-3">
                <img id="mainImage"
                     src="@Url.Content((Model.AnhChinh ?? "no-image.jpg"))"
                     class="img-fluid rounded"
                     style="max-height:400px; object-fit:cover;"
                     onerror="this.src='~/AnhWeb/no-image.jpg';" />
            </div>
            <div class="d-flex gap-2 justify-content-center">
                @if (!string.IsNullOrEmpty(Model.AnhChinh))
                {
                    <img src="@Url.Content(Model.AnhChinh)"
                         onclick="changeImage(this)"
                         class="img-thumbnail active-thumb" style="width:70px;" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu1))
                {
                    <img src="@Url.Content(Model.AnhPhu1)"
                         onclick="changeImage(this)"
                         class="img-thumbnail" style="width:70px;" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu2))
                {
                    <img src="@Url.Content(Model.AnhPhu2)"
                         onclick="changeImage(this)"
                         class="img-thumbnail" style="width:70px;" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu3))
                {
                    <img src="@Url.Content(Model.AnhPhu3)"
                         onclick="changeImage(this)"
                         class="img-thumbnail" style="width:70px;" />
                }
            </div>
        </div>

        <div class="col-lg-6">
            <h2 class="fw-bold">@Model.TenSanPham</h2>
            <h3 class="text-danger my-3">
                @(Model.Gia?.ToString("N0") ?? "0") ₫
            </h3>

            <p class="sold-info mb-3">
                <i class="fas fa-fire"></i> Đã bán @soldCount &nbsp;&nbsp;
                <span class="stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= Math.Ceiling(avgRating) ? "fas fa-star" : "far fa-star") text-warning"></i>
                    }
                </span>
                (@reviewCount đánh giá)
            </p>

            <p class="text-muted">@Model.MoTa</p>

            <div class="border rounded p-4 mb-4 bg-light">
                <h5 class="fw-bold mb-3">Thông tin chi tiết</h5>
                <div class="row">
                    <div class="col-6">
                        <p><strong>Thương hiệu:</strong><br> @(chiTiet?.ThuongHieu?.TenThuongHieu ?? "Đang cập nhật")</p>
                        <p><strong>Chất liệu:</strong><br> @(chiTiet?.ChatLieu?.TenChatLieu ?? "Đang cập nhật")</p>
                        <p><strong>Màu sắc:</strong><br> @(chiTiet?.MauSac?.TenMau ?? "Đang cập nhật")</p>
                    </div>
                    <div class="col-6">
                        <p><strong>Bảo hành:</strong><br> 24 tháng chính hãng</p>
                        <p><strong>Xuất xứ:</strong><br> Việt Nam</p>
                        <p>
                            <strong>Tồn kho:</strong><br>
                            <span class="fw-bold @(conHang ? "text-success" : "text-danger")">
                                @soLuongTon sản phẩm
                            </span>
                        </p>
                    </div>
                </div>
            </div>

            @if (conHang)
            {
                <div class="d-flex align-items-center mb-3">
                    <button class="btn btn-outline-secondary" onclick="updateQuantity(-1)">-</button>
                    <input type="number" id="quantity"
                           class="form-control text-center mx-2"
                           value="1"
                           min="1"
                           max="@soLuongTon"
                           style="width:70px;" />
                    <button class="btn btn-outline-secondary" onclick="updateQuantity(1)">+</button>
                </div>

                <div class="d-flex gap-3">
                    <button id="btnAddCart" data-id="@Model.MaSanPham" class="btn btn-outline-danger w-50">
                        <i class="fas fa-cart-plus"></i> Thêm giỏ
                    </button>
                    <button onclick="muaNgay(this)" data-id="@Model.MaSanPham" class="btn btn-danger w-50">
                        <i class="fas fa-bolt"></i> Mua ngay
                    </button>
                </div>
            }
            else
            {
                <div class="alert alert-danger mt-3">
                    <i class="fas fa-exclamation-triangle"></i> Sản phẩm hiện đang hết hàng
                </div>
            }
        </div>
    </div>

    <!-- REVIEW -->
    <div class="mt-5">
        <h4 class="fw-bold mb-4">Đánh giá sản phẩm (@reviewCount)</h4>

        <div class="card shadow-sm p-4 mb-5">
            <h5>Viết đánh giá</h5>

            @if (Session["MaNguoiDung"] == null)
            {
                <div class="alert alert-warning">
                    Vui lòng đăng nhập để đánh giá
                </div>
            }
            else if (!duocDanhGia)
            {
                <div class="alert alert-info">
                    Bạn cần mua và nhận hàng để đánh giá
                </div>
            }
            else
            {
                <form id="reviewForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaSanPham" value="@Model.MaSanPham" />

                    <div id="starRating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="far fa-star star text-warning" data-value="@i"></i>
                        }
                    </div>

                    <input type="hidden" name="SoSao" id="SoSao" value="5" />

                    <textarea name="NoiDung" class="form-control mt-3" required></textarea>

                    <button type="button" id="btnSubmitReview" class="btn btn-primary mt-3">
                        Gửi đánh giá
                    </button>
                </form>
            }
        </div>

        @foreach (var dg in danhGias)
        {
            <div class="border-bottom mb-3">
                <b>@(dg.NguoiDung?.Ten)</b>
                <div>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= (dg.SoSao ?? 0) ? "fas fa-star text-warning" : "far fa-star")"></i>
                    }
                </div>
                <p>@dg.NoiDung</p>
            </div>
        }
    </div>
</div>

<script>
    // chọn sao
    $(".star").click(function () {
        let value = $(this).data("value");
        $("#SoSao").val(value);

        $(".star").removeClass("fas").addClass("far");
        $(".star").each(function () {
            if ($(this).data("value") <= value) {
                $(this).removeClass("far").addClass("fas");
            }
        });
    });

    // gửi đánh giá
    $("#btnSubmitReview").click(function () {
        $.post("/Home/GuiDanhGia", $("#reviewForm").serialize(), function (res) {
            if (res.success) {
                alert("Đánh giá thành công");
                location.reload();
            } else {
                alert(res.message);
            }
        });
    });

    let maxQuantity = @soLuongTon;

    function changeImage(img) {
        document.getElementById("mainImage").src = img.src;
        document.querySelectorAll('.img-thumbnail').forEach(el => el.classList.remove('active-thumb'));
        img.classList.add('active-thumb');
    }

    // ✅ nút + - vẫn giới hạn (cho đẹp UX)
    function updateQuantity(change) {
        let input = document.getElementById("quantity");
        let value = parseInt(input.value) || 1;

        value += change;

        if (value < 1) value = 1;

        input.value = value;
    }

    // 🔥 CHỈ CHECK Ở ĐÂY
    function muaNgay(btn) {
        let id = $(btn).data("id");
        let soLuong = parseInt($("#quantity").val()) || 1;

        if (soLuong > maxQuantity) {
            Swal.fire({
                icon: 'error',
                title: 'Không đủ hàng',
                text: `Bạn nhập ${soLuong} nhưng chỉ còn ${maxQuantity} sản phẩm trong kho`,
            });
            return;
        }

        window.location.href = `/Home/MuaNgay?id=${id}&soLuong=${soLuong}`;
    }

    // 👉 nên check luôn add cart (tránh lỗi)
    $("#btnAddCart").click(function () {
        let id = $(this).data("id");
        let quantity = parseInt($("#quantity").val()) || 1;

        if (quantity > maxQuantity) {
            Swal.fire({
                icon: 'error',
                title: 'Không đủ hàng',
                text: `Chỉ còn ${maxQuantity} sản phẩm`,
            });
            return;
        }

        $.post("/Home/ThemGioHang", { id: id, quantity: quantity }, function (res) {
            if (res.success) {

                $.get("/Home/LayGioHang", function (cart) {
                    if (cart.success) {
                        $('#cart-count').text(cart.totalQuantity);

                        if (typeof renderMiniCart === "function") {
                            renderMiniCart(cart.cartItems, cart.totalAmount);
                        }
                    }
                });

                Swal.fire({
                    icon: 'success',
                    title: 'Đã thêm vào giỏ',
                    timer: 1500,
                    showConfirmButton: false
                });

            } else {
                Swal.fire('Lỗi', res.message || 'Không thể thêm vào giỏ', 'error');
            }
        });
    });
</script>