@Model DoAnTotNghiep.Models.SanPham
@using DoAnTotNghiep.Models;
@{
    ViewBag.Title = "Chi Tiết Sản Phẩm";
    Layout = null;

    var chiTiet = ViewBag.ChiTietSanPham as ChiTietSanPham;
    var danhGias = ViewBag.DanhGias as List<DanhGia> ?? new List<DanhGia>();
    double avgRating = ViewBag.AverageRating ?? 0;
    int reviewCount = ViewBag.ReviewCount ?? 0;
    int soldCount = ViewBag.SoldCount ?? 0;
    bool conHang = chiTiet != null && chiTiet.SoLuongTon > 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.TenSanPham - Nội Thất Cao Cấp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="@Url.Content("~/Content/chitietsanpham.css")" />
</head>
<body>
    <div class="container">
        <div class="row product-container">
            <!-- Cột hình ảnh -->
            <!-- ==================== PHẦN HÌNH ẢNH SẢN PHẨM ==================== -->
            <div class="col-lg-6">
                <div class="main-image mb-4">
                    <img id="mainImage"
                         src="@Url.Content("~/AnhWeb/" + Model.AnhChinh)"
                         alt="@Model.TenSanPham"
                         onerror="this.src='~/AnhWeb/no-image.jpg';" />
                </div>

                <div class="d-flex gap-3 thumbnail">
                    @if (!string.IsNullOrEmpty(Model.AnhChinh))
                    {
                        <img src="@Url.Content("~/AnhWeb/" + Model.AnhChinh)"
                             onclick="changeImage(this)"
                             class="active"
                             alt="Hình chính" />
                    }
                    @if (!string.IsNullOrEmpty(Model.AnhPhu1))
                    {
                        <img src="@Url.Content("~/AnhWeb/" + Model.AnhPhu1)"
                             onclick="changeImage(this)"
                             alt="Hình phụ 1" />
                    }
                    @if (!string.IsNullOrEmpty(Model.AnhPhu2))
                    {
                        <img src="@Url.Content("~/AnhWeb/" + Model.AnhPhu2)"
                             onclick="changeImage(this)"
                             alt="Hình phụ 2" />
                    }
                    @if (!string.IsNullOrEmpty(Model.AnhPhu3))
                    {
                        <img src="@Url.Content("~/AnhWeb/" + Model.AnhPhu3)"
                             onclick="changeImage(this)"
                             alt="Hình phụ 3" />
                    }
                </div>
            </div>

            <!-- Cột thông tin -->
            <div class="col-lg-6">
                <h1 class="product-title">@Model.TenSanPham</h1>
                <div class="price">@(Model.Gia?.ToString("N0") ?? "0") VNĐ</div>

                <p class="sold-info mt-2">
                    <i class="fas fa-fire"></i> Đã bán @soldCount &nbsp;&nbsp;
                    <span class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="@(i <= Math.Ceiling(avgRating) ? "fas fa-star" : "far fa-star")"></i>
                        }
                    </span>
                    (@reviewCount đánh giá)
                </p>

                <p class="text-muted mt-3">@Model.MoTa</p>

                <!-- Thông tin chi tiết -->
                <div class="info-card">
                    <h5 class="fw-bold mb-3">Thông tin chi tiết</h5>
                    <div class="info-row"><span>Thương hiệu</span><span>@(chiTiet?.ThuongHieu?.TenThuongHieu ?? "Không có")</span></div>
                    <div class="info-row"><span>Chất liệu</span><span>@(chiTiet?.ChatLieu?.TenChatLieu ?? "Không có")</span></div>
                    <div class="info-row"><span>Màu sắc</span><span>@(chiTiet?.MauSac?.TenMau ?? "Không có")</span></div>
                    <div class="info-row">
                        <span>Số lượng tồn kho</span>
                        <span class="fw-bold @(conHang ? "text-success" : "text-danger")">
                            @(chiTiet?.SoLuongTon ?? 0) sản phẩm
                        </span>
                    </div>
                </div>

                <!-- Số lượng và nút hành động -->
                @if (conHang)
                {
                    using (Html.BeginForm("ThemVaoGio", "Home", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaChiTietSanPham" value="@chiTiet.MaChiTiet" />
                        <input type="hidden" name="quantity" id="hiddenQuantity" value="1" />

                        <div class="quantity-group">
                            <div class="quantity-btn" onclick="updateQuantity(-1)">−</div>
                            <input type="text" id="quantity" class="quantity-input form-control" value="1" readonly />
                            <div class="quantity-btn" onclick="updateQuantity(1)">+</div>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-outline-danger btn-action flex-fill">
                                <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                            </button>
                            <button type="button" onclick="muaNgay()" class="btn btn-danger btn-action flex-fill">
                                <i class="fas fa-bolt"></i> Mua ngay
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="out-of-stock">
                        <i class="fas fa-exclamation-triangle"></i> Sản phẩm tạm hết hàng
                    </div>
                }
            </div>
        </div>

        <!-- ==================== PHẦN ĐÁNH GIÁ SẢN PHẨM ==================== -->
        <div class="mx-5 pb-5">
            <h4 class="fw-bold mb-4">Đánh Giá Sản Phẩm (@reviewCount)</h4>

            <!-- Thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <!-- Form viết đánh giá -->
            <div class="card shadow-sm p-4 mb-5">
                <h5 class="mb-3">Viết đánh giá của bạn</h5>

                @using (Html.BeginForm("GuiDanhGia", "Home", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaSanPham" value="@Model.MaSanPham" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">Đánh giá sao của bạn</label>
                        <div id="starRating" class="fs-3 text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="far fa-star star" data-value="@i" style="cursor: pointer; margin-right: 10px;"></i>
                            }
                        </div>
                        <input type="hidden" name="SoSao" id="SoSao" value="5" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Nội dung đánh giá</label>
                        <textarea name="NoiDung" class="form-control" rows="4"
                                  placeholder="Hãy chia sẻ cảm nhận của bạn về sản phẩm..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg px-5">
                        <i class="fas fa-paper-plane"></i> Gửi đánh giá
                    </button>
                }
            </div>

            <!-- Danh sách đánh giá -->
            <h5 class="mb-3">Các đánh giá từ khách hàng</h5>

            @if (danhGias.Any())
            {
                foreach (var dg in danhGias)
                {
                    <div class="border-bottom pb-4 mb-4">
                        <div class="d-flex justify-content-between">
                            <strong>Khách hàng</strong>
                            <small class="text-muted">@dg.NgayDanhGia?.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div class="stars fs-4 mt-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="@(i <= dg.SoSao ? "fas fa-star" : "far fa-star")"></i>
                            }
                        </div>
                        <p class="mt-3">@dg.NoiDung</p>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!</p>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function changeImage(img) {
            document.getElementById('mainImage').src = img.src;
            document.querySelectorAll('.thumbnail img').forEach(el => el.classList.remove('active'));
            img.classList.add('active');
        }

        function updateQuantity(change) {
            let qty = parseInt(document.getElementById('quantity').value);
            let newQty = qty + change;
            if (newQty >= 1) {
                document.getElementById('quantity').value = newQty;
                document.getElementById('hiddenQuantity').value = newQty;
            }
        }

        function muaNgay() {
            alert("Chức năng Mua ngay đang được triển khai. Bạn có thể thêm vào giỏ hàng trước!");
        }

        // JavaScript chọn sao
        document.querySelectorAll('.star').forEach(star => {
            star.addEventListener('click', function () {
                let value = parseInt(this.getAttribute('data-value'));
                document.getElementById('SoSao').value = value;

                document.querySelectorAll('.star').forEach(s => {
                    if (parseInt(s.getAttribute('data-value')) <= value) {
                        s.classList.remove('far');
                        s.classList.add('fas');
                    } else {
                        s.classList.remove('fas');
                        s.classList.add('far');
                    }
                });
            });
        });</script>
</body>
</html>