@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="@Url.Content("~/Content/chitietsanpham.css")" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="~/Scripts/jquery-3.7.1.min.js"></script>
<script src="~/Scripts/sweetalert2.all.min.js"></script>

@model DoAnTotNghiep.Models.SanPham
@using DoAnTotNghiep.Models;

@{
    ViewBag.Title = "Chi Tiết Sản Phẩm";
    var chiTiet = ViewBag.ChiTietSanPham as ChiTietSanPham;
    var danhGias = ViewBag.DanhGias as List<DanhGia> ?? new List<DanhGia>();
    double avgRating = ViewBag.AverageRating ?? 0;
    int reviewCount = ViewBag.ReviewCount ?? 0;
    int soldCount = ViewBag.SoldCount ?? 0;
    int soLuongTon = ViewBag.SoLuongTon ?? 0;
    bool conHang = soLuongTon > 0;
}

<div class="product-page">
    <div class="product-wrapper">
        <div class="col-lg-6">
            <div class="main-image mb-4">
                <img id="mainImage" src="@Url.Content(Model.AnhChinh)" alt="@Model.TenSanPham"
                     onerror="this.src='~/AnhWeb/no-image.jpg';" />
            </div>
            <div class="d-flex gap-3 thumbnail">
                @if (!string.IsNullOrEmpty(Model.AnhChinh))
                {
                    <img src="@Url.Content(Model.AnhChinh)" onclick="changeImage(this)" class="active" alt="Hình chính" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu1))
                {
                    <img src="@Url.Content(Model.AnhPhu1)" onclick="changeImage(this)" alt="Hình phụ 1" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu2))
                {
                    <img src="@Url.Content(Model.AnhPhu2)" onclick="changeImage(this)" alt="Hình phụ 2" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu3))
                {
                    <img src="@Url.Content(Model.AnhPhu3)" onclick="changeImage(this)" alt="Hình phụ 3" />
                }
            </div>
        </div>

        <div class="col-lg-6">
            <h1 class="product-title">@Model.TenSanPham</h1>
            <div class="price">@(Model.Gia?.ToString("N0") ?? "0") VNĐ</div>
            <p class="sold-info mt-2">
                <i class="fas fa-fire"></i> Đã bán @soldCount &nbsp;&nbsp;
                <span class="stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= Math.Ceiling(avgRating) ? "fas fa-star" : "far fa-star")"></i>
                    }
                </span>
                (@reviewCount đánh giá)
            </p>
            <p class="text-muted mt-3">@Model.MoTa</p>

            <div class="info-card">
                <h5 class="fw-bold mb-3">Thông tin chi tiết</h5>
                <div class="info-row"><span>Thương hiệu</span><span>@(chiTiet?.ThuongHieu?.TenThuongHieu ?? "Không có")</span></div>
                <div class="info-row"><span>Chất liệu</span><span>@(chiTiet?.ChatLieu?.TenChatLieu ?? "Không có")</span></div>
                <div class="info-row"><span>Màu sắc</span><span>@(chiTiet?.MauSac?.TenMau ?? "Không có")</span></div>
                <div class="info-row">
                    <span>Số lượng tồn kho</span>
                    <span class="fw-bold @(conHang ? "text-success" : "text-danger")">
                        @soLuongTon sản phẩm
                    </span>
                </div>
            </div>

            @if (conHang)
            {
                <div class="quantity-group mt-4">
                    <div class="quantity-btn" onclick="updateQuantity(-1)">−</div>
                    <input type="text" id="quantity" class="quantity-input form-control" value="1" readonly />
                    <div class="quantity-btn" onclick="updateQuantity(1)">+</div>
                </div>

                <div class="d-flex gap-3 mt-3">
                    <button id="btnAddCart" class="btn btn-danger px-4 py-2" data-id="@Model.MaSanPham">
                        <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                    </button>
                    <button type="button" onclick="muaNgay(this)" data-id="@Model.MaSanPham"
                            class="btn btn-danger btn-action flex-fill">
                        <i class="fas fa-bolt"></i> Mua ngay
                    </button>
                </div>
            }
            else
            {
                <div class="out-of-stock mt-4">
                    <i class="fas fa-exclamation-triangle"></i> Sản phẩm tạm hết hàng
                </div>
            }
        </div>
    </div>

    <!-- Phần đánh giá giữ nguyên (không thay đổi) -->
    <div class="mx-5 pb-5">
        <!-- ... phần đánh giá của bạn giữ nguyên ... -->
        @* (bạn copy phần đánh giá cũ vào đây) *@
    </div>
</div>

<script>
    let maxQuantity = @soLuongTon;   // Số lượng tồn kho tối đa

    function changeImage(img) {
        document.getElementById('mainImage').src = img.src;
        document.querySelectorAll('.thumbnail img').forEach(el => el.classList.remove('active'));
        img.classList.add('active');
    }

    function updateQuantity(change) {
        let input = document.getElementById("quantity");
        let qty = parseInt(input.value) || 1;
        let newQty = qty + change;

        if (newQty < 1) newQty = 1;
        if (newQty > maxQuantity) newQty = maxQuantity;

        input.value = newQty;
    }

    function muaNgay(btn) {
        let id = $(btn).data("id");
        let soLuong = parseInt($("#quantity").val()) || 1;

        if (soLuong > maxQuantity) {
            Swal.fire({
                icon: 'error',
                title: 'Vượt tồn kho',
                text: `Chỉ còn ${maxQuantity} sản phẩm. Vui lòng chọn ít hơn!`
            });
            $("#quantity").val(maxQuantity);
            return;
        }

        $.post('/Home/ThemGioHang', { id: id, soLuong: soLuong }, function (res) {
            if (res.success) {
                window.location.href = '/Home/ThanhToan';
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Lỗi',
                    text: res.message || 'Không thể mua ngay lúc này'
                });
            }
        });
    }

    // Xử lý Thêm vào giỏ hàng
    $(document).ready(function () {
        $("#btnAddCart").click(function (e) {
            e.preventDefault();

            let spId = $(this).data("id");
            let quantity = parseInt($("#quantity").val()) || 1;

            if (quantity > maxQuantity) {
                Swal.fire({
                    icon: "error",
                    title: "Vượt quá tồn kho",
                    text: `Sản phẩm chỉ còn ${maxQuantity} cái. Vui lòng giảm số lượng!`
                });
                $("#quantity").val(maxQuantity);
                return;
            }

            $.ajax({
                url: '@Url.Action("ThemGioHang", "Home")',
                type: "POST",
                data: { id: spId, soLuong: quantity },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: "success",
                            title: "Đã thêm vào giỏ hàng!",
                            showConfirmButton: false,
                            timer: 1500
                        });

                        // Cập nhật số lượng giỏ hàng (nếu có hàm global)
                        if (typeof updateMiniCart === "function") {
                            updateMiniCart(res);
                        }
                    } else {
                        Swal.fire({
                            icon: "warning",
                            title: "Thông báo",
                            text: res.message || "Không thể thêm vào giỏ hàng"
                        });
                    }
                },
                error: function () {
                    Swal.fire({
                        icon: "error",
                        title: "Lỗi kết nối",
                        text: "Vui lòng thử lại sau"
                    });
                }
            });
        });
    });

    // Star rating (giữ nguyên)
    document.querySelectorAll('.star').forEach(star => {
        star.addEventListener('click', function () {
            let value = parseInt(this.getAttribute('data-value'));
            document.getElementById('SoSao').value = value;
            document.querySelectorAll('.star').forEach(s => {
                s.classList.toggle('fas', parseInt(s.getAttribute('data-value')) <= value);
                s.classList.toggle('far', parseInt(s.getAttribute('data-value')) > value);
            });
        });
    });
</script>