@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="@Url.Content("~/Content/chitietsanpham.css")" />
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="~/Scripts/jquery-3.7.1.min.js"></script>
<script src="~/Scripts/sweetalert2.all.min.js"></script>
@model DoAnTotNghiep.Models.SanPham
@using DoAnTotNghiep.Models;
@{
    ViewBag.Title = "Chi Tiết Sản Phẩm";
    var chiTiet = ViewBag.ChiTietSanPham as ChiTietSanPham;
    var danhGias = ViewBag.DanhGias as List<DanhGia> ?? new List<DanhGia>();
    double avgRating = ViewBag.AverageRating ?? 0;
    int reviewCount = ViewBag.ReviewCount ?? 0;
    int soldCount = ViewBag.SoldCount ?? 0;
    bool conHang = chiTiet != null && chiTiet.SoLuongTon > 0;
}
<div class="product-page">
    <div class="product-wrapper">
        <div class="col-lg-6">
            <div class="main-image mb-4">
                <img id="mainImage"
                     src="@Url.Content(Model.AnhChinh)"
                     alt="@Model.TenSanPham"
                     onerror="this.src='~/AnhWeb/no-image.jpg';" />
            </div>

            <div class="d-flex gap-3 thumbnail">
                @if (!string.IsNullOrEmpty(Model.AnhChinh))
                {
                    <img src="@Url.Content(Model.AnhChinh)"
                         onclick="changeImage(this)"
                         class="active"
                         alt="Hình chính" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu1))
                {
                    <img src="@Url.Content(Model.AnhPhu1)"
                         onclick="changeImage(this)"
                         alt="Hình phụ 1" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu2))
                {
                    <img src="@Url.Content(Model.AnhPhu2)"
                         onclick="changeImage(this)"
                         alt="Hình phụ 2" />
                }
                @if (!string.IsNullOrEmpty(Model.AnhPhu3))
                {
                    <img src="@Url.Content(Model.AnhPhu3)"
                         onclick="changeImage(this)"
                         alt="Hình phụ 3" />
                }
            </div>
        </div>

        <div class="col-lg-6">
            <h1 class="product-title">@Model.TenSanPham</h1>
            <div class="price">@(Model.Gia?.ToString("N0") ?? "0") VNĐ</div>

            <p class="sold-info mt-2">
                <i class="fas fa-fire"></i> Đã bán @soldCount &nbsp;&nbsp;
                <span class="stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= Math.Ceiling(avgRating) ? "fas fa-star" : "far fa-star")"></i>
                    }
                </span>
                (@reviewCount đánh giá)
            </p>

            <p class="text-muted mt-3">@Model.MoTa</p>
            <div class="info-card">
                <h5 class="fw-bold mb-3">Thông tin chi tiết</h5>
                <div class="info-row"><span>Thương hiệu</span><span>@(chiTiet?.ThuongHieu?.TenThuongHieu ?? "Không có")</span></div>
                <div class="info-row"><span>Chất liệu</span><span>@(chiTiet?.ChatLieu?.TenChatLieu ?? "Không có")</span></div>
                <div class="info-row"><span>Màu sắc</span><span>@(chiTiet?.MauSac?.TenMau ?? "Không có")</span></div>
                <div class="info-row">
                    <span>Số lượng tồn kho</span>
                    <span class="fw-bold @(conHang ? "text-success" : "text-danger")">
                        @(chiTiet?.SoLuongTon ?? 0) sản phẩm
                    </span>
                </div>
            </div>
            @if (conHang)
            {
                using (Html.BeginForm("ThemVaoGio", "Home", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaChiTietSanPham" value="@chiTiet.MaChiTiet" />
                    <input type="hidden" name="quantity" id="hiddenQuantity" value="1" />

                    <div class="quantity-group">
                        <div class="quantity-btn" onclick="updateQuantity(-1)">−</div>

                        <input type="text"
                               id="quantity"
                               class="quantity-input form-control"
                               value="1"
                               readonly />

                        <div class="quantity-btn" onclick="updateQuantity(1)">+</div>
                    </div>

                    <div class="d-flex gap-3">
                        <button
                                class="add-cart btn btn-danger px-4 py-2"
                                data-id="@Model.MaSanPham">
                            <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                        </button>
                        <button type="button"
                                onclick="muaNgay(this)"
                                data-id="@Model.MaSanPham"
                                class="btn btn-danger btn-action flex-fill">
                            <i class="fas fa-bolt"></i> Mua ngay
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="out-of-stock">
                    <i class="fas fa-exclamation-triangle"></i> Sản phẩm tạm hết hàng
                </div>
            }
        </div>
    </div>
    <div class="mx-5 pb-5">
        <h4 class="fw-bold mb-4">Đánh Giá Sản Phẩm (@reviewCount)</h4>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (Session["MaNguoiDung"] != null)
        {
            <div class="card shadow-sm p-4 mb-5">
                <h5 class="mb-3">Viết đánh giá của bạn</h5>

                @using (Html.BeginForm("GuiDanhGia", "Home", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaSanPham" value="@Model.MaSanPham" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">Đánh giá sao của bạn</label>

                        <div id="starRating" class="fs-3 text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="far fa-star star" data-value="@i"></i>
                            }
                        </div>

                        <input type="hidden" name="SoSao" id="SoSao" value="5" />
                    </div>

                    <div class="mb-4">
                        <textarea name="NoiDung"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Hãy chia sẻ cảm nhận của bạn..."
                                  required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Gửi đánh giá
                    </button>
                }
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                🔒 Bạn cần đăng nhập để đánh giá sản phẩm.
            </div>
        }
        <h5 class="mb-4 fw-bold">Các đánh giá từ khách hàng</h5>

        @if (danhGias.Any())
        {
            foreach (var dg in danhGias)
            {
                <div class="review-item">

                    <div class="d-flex justify-content-between align-items-center">
                        <strong>
                            @(dg.NguoiDung != null ? dg.NguoiDung.Ten : "Người dùng")
                        </strong>

                        <small class="text-muted">
                            @(dg.NgayDanhGia?.ToString("dd/MM/yyyy HH:mm") ?? "")
                        </small>
                    </div>

                    <div class="review-stars mt-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="@(i <= dg.SoSao ? "fas fa-star" : "far fa-star")"></i>
                        }
                    </div>

                    <p class="review-content mt-2">
                        @dg.NoiDung
                    </p>

                </div>
            }
        }
        else
        {
            <p class="text-muted">
                Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!
            </p>
        }
    </div>
</div>

<script src="~/Scripts/bootstrap.bundle.min.js"></script>
<script>
    function changeImage(img) {
        document.getElementById('mainImage').src = img.src;
        document.querySelectorAll('.thumbnail img')
            .forEach(el => el.classList.remove('active'));
        img.classList.add('active');
    }

    function updateQuantity(change) {
        let qty = parseInt(document.getElementById('quantity').value);
        let newQty = qty + change;

        if (newQty < 1) return;

        document.getElementById('quantity').value = newQty;
        document.getElementById('hiddenQuantity').value = newQty;
    }

    function muaNgay(btn) {

        let id = $(btn).data("id");
        let soLuong = $("#hiddenQuantity").val();

        $.post('/Home/ThemGioHang', { id: id, soLuong: soLuong }, function (res) {

            if (res.success) {

                window.location.href = '/Home/ThanhToan';

            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Lỗi',
                    text: res.message
                });
            }
        });
    }
    document.querySelectorAll('.star').forEach(star => {
        star.addEventListener('click', function () {

            let value = parseInt(this.getAttribute('data-value'));
            document.getElementById('SoSao').value = value;

            document.querySelectorAll('.star').forEach(s => {

                if (parseInt(s.getAttribute('data-value')) <= value) {
                    s.classList.remove('far');
                    s.classList.add('fas');
                } else {
                    s.classList.remove('fas');
                    s.classList.add('far');
                }
            });
        });
    });

    function validateDanhGia() {

        let soSao = document.getElementById('SoSao').value;

        if (!soSao || soSao == "0") {
            alert("⭐ Vui lòng chọn sao để đánh giá!");
            return false;
        }

        return true;
    }
        $(document).ready(function () {
            $(document).off('click', '.add-cart').on('click', '.add-cart', function (e) {
                e.preventDefault();

                var spId = $(this).data('id');
                var addCartUrl = '@Url.Action("ThemGioHang","Home")';

                $.ajax({
                    url: addCartUrl,
                    type: 'POST',
                    data: { id: spId },
                    success: function (res) {
                        if (res.success) {
                            $('#cart-count').text(res.totalQuantity);

                            if (typeof updateMiniCart === "function") {
                                updateMiniCart(res.cartItems, res.totalAmount);
                            }

                            Swal.fire({
                                icon: 'success',
                                title: 'Đã thêm vào giỏ!',
                                showConfirmButton: false,
                                timer: 1000
                            });
                            $('.mini-cart-dropdown').addClass('active');
                            setTimeout(function() {
                                $('.mini-cart-dropdown').removeClass('active');
                            }, 2500);
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'Thông báo',
                                text: res.message
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Lỗi chi tiết:", xhr.responseText);
                        alert("Không tìm thấy đường dẫn xử lý (Lỗi 404). Mạnh hãy kiểm tra lại tên Controller!");
                    }
                });
            });
        });

</script>

