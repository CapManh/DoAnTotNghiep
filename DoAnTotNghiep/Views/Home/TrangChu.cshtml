                    <div class="price">
                        <span>2.860.000 đ</span>
                    </div>

                    <button class="add-cart">Thêm Vào Giỏ Hàng</button>
                </div>

            </div>

            <!-- 2 -->
            <div class="product-card">

                <div class="img-box">
                    <img src="@Url.Content("~/AnhWeb/ban2.png")" />
                    <a href="/SanPham/ChiTiet/2" class="view-btn">👁</a>
                </div>

                <div class="stars">★★★★★</div>
