        <script>
            /* ================= SLIDER SẢN PHẨM (NP) ================= */
            const track = document.querySelector(".np-track");
            const items = document.querySelectorAll(".np-item");

            const prevBtn = document.querySelector(".np-prev");
            const nextBtn = document.querySelector(".np-next");

            let npIndex = 0;
            const itemsPerPage = 4;

            function moveSlide() {
                const itemWidth = items[0].offsetWidth;
                const moveX = itemWidth * itemsPerPage * npIndex;
                track.style.transform = `translateX(-${moveX}px)`;

                updateDots();
            }

            const maxIndex = Math.ceil(items.length / itemsPerPage) - 1;

            nextBtn.onclick = () => {
                npIndex = (npIndex < maxIndex) ? npIndex + 1 : 0;
                moveSlide();
            };

            prevBtn.onclick = () => {
                npIndex = (npIndex > 0) ? npIndex - 1 : maxIndex;
                moveSlide();
            };


            /* ================= DOTS ================= */
            const dots = document.querySelectorAll(".np-dot");

            function updateDots() {
                dots.forEach(dot => dot.classList.remove("active"));
                dots[npIndex].classList.add("active");
            }


            /* ================= BANNER TRÊN ================= */
            let bannerIndex = 0;
            const slides = document.getElementById("slides");
            const total = document.querySelectorAll(".slide").length;

            setInterval(() => {
                bannerIndex = (bannerIndex + 1) % total;
                slides.style.transform = `translateX(-${bannerIndex * 100}%)`;
            }, 3000);
        </script>




