@model List<DoAnTotNghiep.Models.GioHang>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = Session["TenNguoiDung"]?.ToString() ?? "";
    var email = Session["Email"]?.ToString() ?? "";
    var sdt = Session["SDT"]?.ToString() ?? "";
    var diaChi = Session["DiaChi"]?.ToString() ?? "";

    var gioHang = Model ?? new List<DoAnTotNghiep.Models.GioHang>();

    var tongTienGoc = gioHang.Sum(x => (x.SanPham?.Gia ?? 0) * (x.SoLuong ?? 0));
    var phiVanChuyen = 39000m;
    var tongThanhToan = tongTienGoc + phiVanChuyen;
}

<div class="container my-5">

    @using (Html.BeginForm("DatHang", "Home", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <input type="hidden" id="TongTienInput" name="TongTien" value="@tongThanhToan" />
        <input type="hidden" id="MaKhuyenMaiHidden" name="MaKhuyenMai" />

        <div class="row g-4">

            <!-- LEFT -->
            <div class="col-lg-7">

                <div class="card p-4 mb-4">
                    <h5>Thông tin nhận hàng</h5>


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" name="HoTen" class="form-control" value="@user" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                            <input type="text" name="SoDienThoai" class="form-control" value="@sdt" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email" class="form-control" value="@email" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <input type="text" name="DiaChi" class="form-control" value="@diaChi" required />
                        </div>
                    </div>
                </div>

                <div class="card p-4">
                    <h5>Phương thức thanh toán</h5>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="MaPhuongThuc" value="2" checked />
                        <label class="form-check-label">QR (Chuyển khoản)</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="MaPhuongThuc" value="5" />
                        <label class="form-check-label">COD (Thanh toán khi nhận)</label>
                    </div>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-5">

                <div class="card p-4 shadow-sm rounded-3 sticky-top" style="top: 20px;">

                    <h4 class="mb-3">Đơn hàng của bạn</h4>

                    @if (gioHang.Any())
                    {
                        foreach (var item in gioHang)
                        {
                            var gia = item.SanPham?.Gia ?? 0;
                            var sl = item.SoLuong ?? 0;

                            <div class="d-flex align-items-center justify-content-between border-bottom py-2">

                                <div class="d-flex align-items-center">

                                    <!-- ẢNH -->
                                    <img src="~/AnhWeb/@(item.SanPham?.AnhChinh ?? "no-image.png")"
                                         style="width:60px; height:60px; object-fit:cover; border-radius:8px; margin-right:10px;" />

                                    <!-- TÊN -->
                                    <div>
                                        <b>@(item.SanPham?.TenSanPham ?? "SP lỗi")</b><br />
                                        <small>Số lượng: @sl</small>
                                    </div>

                                </div>

                                <!-- GIÁ -->
                                <div class="text-end">
                                    @(string.Format("{0:N0}", gia * sl)) ₫
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-danger">⚠ Không có sản phẩm</p>
                    }

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Tổng tiền hàng</span>
                        <b id="tongTienHang">@tongTienGoc.ToString("N0") ₫</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Phí vận chuyển</span>
                        <b>@phiVanChuyen.ToString("N0") ₫</b>
                    </div>

                    <hr />

                    <div class="mb-4">
                        <label class="fw-bold mb-2">Mã khuyến mãi</label>

                        <div class="input-group">
                            <input type="text" id="MaGiamGiaInput" class="form-control" placeholder="Nhập mã giảm giá" />
                            <button type="button" id="btnApDungVoucher" class="btn btn-dark">
                                Áp dụng
                            </button>
                        </div>

                        <small id="voucherMsg" class="text-success"></small>
                        <small id="voucherError" class="text-danger"></small>
                    </div>

                    <div id="codDepositBox" class="alert alert-warning mt-3 d-none">
                        <b>✅ Bạn chỉ cần đặt cọc 10%</b><br>
                        Đặt cọc: <span id="tienDatCoc"></span><br>
                        Còn lại: <span id="tienConLai"></span>
                    </div>

                    <div class="d-flex justify-content-between fs-4 fw-bold">
                        <span>Tổng thanh toán</span>
                        <span class="text-danger" id="TongTienText">@tongThanhToan.ToString("N0") ₫</span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 mt-4 py-3 fs-5">
                        ĐẶT HÀNG NGAY
                    </button>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts{
    <script>
        function formatMoney(n) {
            return n.toLocaleString('vi-VN') + ' ₫';
        }

        function updatePayment() {
            const method = document.querySelector('input[name="MaPhuongThuc"]:checked').value;
            const tongTien = parseFloat($('#TongTienText').text().replace(/[^0-9]/g, ''));

            if (!tongTien) return;

            const box = $('#codDepositBox');

            if (method == "5") { // ✅ COD đúng
                const datCoc = Math.round(tongTien * 0.1);
                const conLai = tongTien - datCoc;

                $('#tienDatCoc').text(formatMoney(datCoc));
                $('#tienConLai').text(formatMoney(conLai));

                box.removeClass('d-none');
            } else {
                box.addClass('d-none');
            }
        }

        $('input[name="MaPhuongThuc"]').change(updatePayment);

        $(document).ready(function () {
            updatePayment();
        });
    </script>
}