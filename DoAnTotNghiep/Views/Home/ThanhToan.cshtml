@model List<DoAnTotNghiep.Models.GioHang>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = Session["TenNguoiDung"]?.ToString() ?? "";
    var email = Session["Email"]?.ToString() ?? "";
    var sdt = Session["SDT"]?.ToString() ?? "";
    var diaChi = Session["DiaChi"]?.ToString() ?? "";

    var gioHang = Model ?? new List<DoAnTotNghiep.Models.GioHang>();

    var tongTienGoc = gioHang.Sum(x => (x.SanPham?.Gia ?? 0) * (x.SoLuong ?? 0));
    var phiVanChuyen = 39000m;
    var tongThanhToan = tongTienGoc + phiVanChuyen;

    bool isMuaNgay = ViewBag.MuaNgay != null && (bool)ViewBag.MuaNgay;
}

<div class="container my-5">

    @using (Html.BeginForm("DatHang", "Home", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <input type="hidden" name="MuaNgay" value="@isMuaNgay.ToString().ToLower()" />
        <input type="hidden" name="ids" value="@ViewBag.Ids" />
        if (isMuaNgay && gioHang.Any())
        {
            <input type="hidden" name="MaSanPham" value="@gioHang.First().MaSanPham" />
            <input type="hidden" name="SoLuong" value="@gioHang.First().SoLuong" />
        }

        <input type="hidden" id="TongTienInput" name="TongTien" value="@tongThanhToan" />
        <input type="hidden" id="MaKhuyenMaiHidden" name="MaKhuyenMai" />

        <div class="row g-4">

            <!-- LEFT -->
            <div class="col-lg-7">

                <div class="card p-4 mb-4">
                    <h5>Thông tin nhận hàng</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label>Họ và tên *</label>
                            <input type="text" name="HoTen" class="form-control" value="@user" required />
                        </div>
                        <div class="col-md-6">
                            <label>SĐT *</label>
                            <input type="text" name="SoDienThoai" class="form-control" value="@sdt" required />
                        </div>
                        <div class="col-12">
                            <label>Email</label>
                            <input type="email" name="Email" class="form-control" value="@email" />
                        </div>
                        <div class="col-12">
                            <label>Địa chỉ *</label>
                            <input type="text" name="DiaChi" class="form-control" value="@diaChi" required />
                        </div>
                    </div>
                </div>

                <div class="card p-4">
                    <h5>Phương thức thanh toán</h5>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="MaPhuongThuc" value="2" checked />
                        <label>QR (Chuyển khoản)</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="MaPhuongThuc" value="5" />
                        <label>COD</label>
                    </div>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-5">

                <div class="card p-4 shadow-sm sticky-top" style="top:20px;">

                    <h4>Đơn hàng (@gioHang.Count sản phẩm)</h4>

                    @if (gioHang.Any())
                    {
                        foreach (var item in gioHang)
                        {
                            var gia = item.SanPham?.Gia ?? 0;
                            var sl = item.SoLuong ?? 1;

                            <div class="d-flex justify-content-between border-bottom py-3">
                                <div class="d-flex">
                                    <img src="@Url.Content(item.SanPham?.AnhChinh ?? "~/AnhWeb/no-image.png")"
                                         style="width:60px;height:60px;object-fit:cover;margin-right:10px;" />

                                    <div>
                                        <b>@(item.SanPham?.TenSanPham ?? "SP lỗi")</b><br />
                                        <small>Số lượng: @sl</small>
                                    </div>
                                </div>

                                <b>@String.Format("{0:N0}", gia * sl) ₫</b>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-danger">Không có sản phẩm</p>
                    }
                    <hr />
                    <div class="card shadow-sm p-3 mb-3">

                        <label class="fw-bold mb-2">
                            Mã giảm giá
                        </label>

                        <div class="input-group">

                            <input type="text"
                                   id="voucher-code"
                                   class="form-control"
                                   placeholder="Nhập mã giảm giá">

                            <button type="button"
                                    class="btn btn-danger"
                                    id="btn-apdung-voucher">
                                Áp dụng
                            </button>
</div>

                        <small id="voucher-message"
                               class="text-success mt-2 d-block"></small>

                    </div>
                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Tiền hàng</span>
                        <b>@tongTienGoc.ToString("N0") ₫</b>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Ship</span>
                        <b>@phiVanChuyen.ToString("N0") ₫</b>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between fs-5">
                        <b>Tổng</b>
                        <b class="text-danger" id="TongTienText">@tongThanhToan.ToString("N0") ₫</b>
                    </div>

                    <div id="codBox" class="alert alert-warning mt-3 d-none"></div>

                    <button type="submit" class="btn btn-dark w-100 mt-3 py-3">
                        ĐẶT HÀNG
                    </button>
                </div>

            </div>

        </div>
    }
</div>

@section Scripts{
    <script>
        function format(n) {
            return n.toLocaleString('vi-VN') + ' ₫';
        }

        function getTongTien() {
            return parseInt($('#TongTienText').text().replace(/[^0-9]/g, '')) || 0;
        }

        function updateCOD() {
            let method = $('input[name="MaPhuongThuc"]:checked').val();
            let tong = getTongTien();

            let hienThiTong = tong;

            if (method == "5") {
                let datCoc = Math.round(tong * 0.1);
                let conLai = tong - datCoc;

                hienThiTong = datCoc;

                $('#codBox')
                    .removeClass('d-none')
                    .html(`
                Đặt cọc: <b>${format(datCoc)}</b><br>
                Còn lại: <b>${format(conLai)}</b>
            `);
            } else {
                $('#codBox').addClass('d-none').html('');
            }

            $('#TongTienText').text(format(hienThiTong) + ' ₫');
        }

        $('input[name="MaPhuongThuc"]').change(updateCOD);

        $(document).ready(function () {
            updateCOD();
        });
        $('#btn-apdung-voucher').click(function () {

            let code = $('#voucher-code').val();

            if (!code) {
                $('#voucher-message')
                    .removeClass('text-success')
                    .addClass('text-danger')
                    .text("Vui lòng nhập mã giảm giá");

                return;
            }

            let tongTien = getTongTien();

            $.post('/Home/ApDungVoucher',
                {
                    code: code,
                    tongTien: tongTien
                },
                function (res) {

                    if (res.success) {

                        $('#voucher-message')
                            .removeClass('text-danger')
                            .addClass('text-success')
                            .text(res.message);

                        $('#TongTienText')
                            .text(res.tongSauGiam.toLocaleString() + ' ₫');

                        $('#TongTienInput')
                            .val(res.tongSauGiam);

                        $('#MaKhuyenMaiHidden')
                            .val(res.maKhuyenMai);

                        updateCOD();
                    }
                    else {

                        $('#voucher-message')
                            .removeClass('text-success')
                            .addClass('text-danger')
                            .text(res.message);
                    }
                });
        });
    </script>
}