@model IEnumerable<DoAnTotNghiep.Models.SanPham>

@{
    ViewBag.Title = "Quản lý Sản phẩm";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý sản phẩm</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            background: #eef2f7;
            font-family: 'Segoe UI', sans-serif;
        }

        h2 {
            font-weight: 700;
            color: #2c3e50;
        }

        /* HEADER */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        /* CARD */
        .card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        /* TABLE */
        .table {
            margin: 0;
        }

            .table thead {
                background: linear-gradient(45deg, #4e73df, #224abe);
                color: white;
            }

            .table th {
                border: none;
                text-align: center;
                font-size: 14px;
            }

            .table td {
                text-align: center;
                vertical-align: middle;
                border-top: 1px solid #f1f1f1;
            }

            .table tbody tr {
                transition: 0.25s;
            }

                .table tbody tr:hover {
                    background: #f4f8ff;
                }

        /* IMAGE */
        .img-main {
            width: 65px;
            height: 65px;
            object-fit: cover;
            border-radius: 10px;
            border: 2px solid #eee;
            transition: 0.3s;
        }

            .img-main:hover {
                transform: scale(1.1);
            }

        .img-sub {
            width: 42px;
            height: 42px;
            object-fit: cover;
            border-radius: 8px;
            margin: 2px;
            border: 1px solid #ddd;
            transition: 0.3s;
        }

            .img-sub:hover {
                transform: scale(1.15);
            }

        /* PRICE */
        .price {
            color: #e74a3b;
            font-weight: 700;
        }

        /* STOCK */
        .stock-low {
            color: #e74a3b;
            font-weight: bold;
        }

        .stock-ok {
            color: #1cc88a;
            font-weight: bold;
        }

        /* BADGE */
        .badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
        }

        /* BUTTON */
        .btn-success {
            border-radius: 10px;
        }

        .btn-warning {
            background: #f6c23e;
            border: none;
        }

        .btn-danger {
            background: #e74a3b;
            border: none;
        }

        .btn-warning:hover {
            background: #dda20a;
        }

        .btn-danger:hover {
            background: #c0392b;
        }

        /* SEARCH */
        .form-control {
            border-radius: 10px;
            padding: 10px;
        }

        .btn-primary {
            border-radius: 10px;
            padding: 10px 18px;
            background: #4e73df;
            border: none;
        }

        /* PAGINATION */
        .custom-circle-pagination .page-link {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            text-align: center;
            line-height: 26px;
            margin: 0 5px;
            border: none;
            background: #e9ecef;
            color: #333;
        }

        .custom-circle-pagination .active .page-link {
            background: #4e73df;
            color: white;
            font-weight: bold;
        }
    </style>
</head>

<body class="p-4">

    <!-- HEADER -->
    <div class="top-bar">
        <h2>📦 Quản lý Sản phẩm</h2>
        <a href="@Url.Action("ThemSanPham")" class="btn btn-success shadow">
            <i class="fas fa-plus"></i> Thêm sản phẩm
        </a>
    </div>

    <!-- SEARCH -->
    <div class="row mb-4">
        <div class="col-md-5">
            <form method="get" class="d-flex">
                <input type="text" name="search" value="@ViewBag.Search"
                       class="form-control me-2" placeholder="🔍 Tìm kiếm sản phẩm..." />
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card">
        <div class="card-body p-0">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>Tên</th>
                        <th>Danh mục</th>
                        <th>Thương hiệu</th>
                        <th>Chất liệu</th>
                        <th>Màu</th>
                        <th>Giá</th>
                        <th>Tồn</th>
                        <th>Nổi bật</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var chiTiet = item.ChiTietSanPham?.FirstOrDefault();

                        <tr>
                            <td><strong>@item.MaSanPham</strong></td>

                            <td>
                                <!-- Ảnh chính -->
                                @if (!string.IsNullOrEmpty(item.AnhChinh))
                                {
                                    <img src="@Url.Content(item.AnhChinh)"
                                         class="img-sub"
                                         alt="@item.TenSanPham"
                                         onerror="this.src='/AnhWeb/no-image.jpg'; this.onerror=null;" />
                                }
                                else
                                {
                                    <span class="text-muted">Không có ảnh</span>
                                }

                                <!-- Các ảnh phụ -->
                                <div class="mt-2 d-flex flex-wrap gap-1">
                                    @if (!string.IsNullOrEmpty(item.AnhPhu1))
                                    {
                                        <img src="~/AnhWeb/@item.AnhPhu1"
                                             class="img-sub"
                                             alt="Phụ 1"
                                             onerror="this.style.display='none';" />
                                    }
                                    @if (!string.IsNullOrEmpty(item.AnhPhu2))
                                    {
                                        <img src="~/AnhWeb/@item.AnhPhu2"
                                             class="img-sub"
                                             alt="Phụ 2"
                                             onerror="this.style.display='none';" />
                                    }
                                    @if (!string.IsNullOrEmpty(item.AnhPhu3))
                                    {
                                        <img src="~/AnhWeb/@item.AnhPhu3"
                                             class="img-sub"
                                             alt="Phụ 3"
                                             onerror="this.style.display='none';" />
                                    }
                                </div>
                            </td>

                            <td><strong>@item.TenSanPham</strong></td>
                            <td>@(item.DanhMuc?.TenDanhMuc ?? "—")</td>
                            <td>@(chiTiet?.ThuongHieu?.TenThuongHieu ?? "—")</td>
                            <td>@(chiTiet?.ChatLieu?.TenChatLieu ?? "—")</td>
                            <td>@(chiTiet?.MauSac?.TenMau ?? "—")</td>

                            <td class="price">
                                <span>@string.Format("{0:N0}", item.Gia ?? 0) đ</span>
                            </td>

                            <td>
                                @if (chiTiet != null)
                                {
                                    <span class="@(chiTiet.SoLuongTon < 5 ? "stock-low" : "stock-ok")">
                                        @chiTiet.SoLuongTon
                                    </span>
                                }
                                else
                                {
                                    <span>0</span>
                                }
                            </td>

                            <td>
                                @if (item.NoiBat == true)
                                {
                                    <span class="badge bg-success">⭐</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">—</span>
                                }
                            </td>

                            <td>
                                <a href="@Url.Action("ChinhSuaSanPham", "Admin", new { id = item.MaSanPham })"
                                   class="btn btn-warning btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>

                                @using (Html.BeginForm("XoaSanPham", "Admin", FormMethod.Post, new { id = "deleteForm_" + item.MaSanPham }))
                                {
                                    <input type="hidden" name="id" value="@item.MaSanPham" />

                                    <button type="button"
                                            class="btn btn-danger btn-sm"
                                            onclick="confirmDelete(@item.MaSanPham, '@item.TenSanPham')">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- PAGINATION -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center custom-circle-pagination">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("QuanLySanPham", new { page = i, search = ViewBag.Search })">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <script>function confirmDelete(id, ten) {
            if (confirm("Xóa sản phẩm: " + ten + "?")) {
                document.getElementById('deleteForm_' + id).submit();
            }
        }</script>

</body>
</html>