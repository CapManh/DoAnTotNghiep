@model List<DoAnTotNghiep.Models.DanhMuc>
@{
    ViewBag.Title = "quản lý danh mục";
    Layout = "~/Views/Shared/Admin.cshtml";
}
<h2>Quản lý danh mục</h2>

<a href="@Url.Action("themdm")" class="btn btn-success mb-3">+ Thêm danh mục</a>

<table class="table table-bordered">
    <tr>
        <th>Tên danh mục</th>
        <th>Mô tả</th>
        <th>Chức năng</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.TenDanhMuc</td>
            <td>@item.MoTa</td>
            <td>
                <a href="@Url.Action("suadm", new { id = item.MaDanhMuc })" class="btn btn-warning">Sửa</a>
                <a href="@Url.Action("xoadm", new { id = item.MaDanhMuc })"
                   onclick="return confirm('Xóa?')"
                   class="btn btn-danger">Xóa</a>
            </td>
        </tr>
    }
</table>