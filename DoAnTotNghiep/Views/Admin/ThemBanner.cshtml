@model DoAnTotNghiep.Models.Banner

@{
    ViewBag.Title = "Thêm Banner";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #eef2f7;
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    }

    .card-header {
        background: linear-gradient(45deg, #1cc88a, #17a673);
        color: white;
        border-radius: 18px 18px 0 0;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px;
    }

    .form-label {
        font-weight: 600;
    }

    .banner-preview {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px dashed #ddd;
    }

    .btn {
        border-radius: 10px;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 15px;
        color: #1cc88a;
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-image"></i> Thêm Banner</h2>

        <a href="@Url.Action("QuanLyBanner")" class="btn btn-secondary">
            ← Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            🚀 Tạo banner mới
        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            @using (Html.BeginForm("ThemBanner", "Admin", FormMethod.Post,
                new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <div class="section-title">Thông tin banner</div>

                        <div class="mb-3">
                            <label class="form-label">Tiêu đề</label>
                            @Html.TextBoxFor(m => m.TieuDe, new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Link</label>
                            @Html.TextBoxFor(m => m.Link, new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Vị trí</label>
                            @Html.DropDownListFor(m => m.ViTri,
                                     new SelectList(new[] {
                                    "Trang chủ", "Sidebar"
                         }),
                                     "-- Chọn vị trí --",
                                     new { @class = "form-select" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Thứ tự</label>
                            @Html.TextBoxFor(m => m.ThuTu, new { @class = "form-control", type = "number" })
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="section-title">Hình ảnh & hiển thị</div>

                        <div class="mb-3">
                            <label class="form-label">Ảnh banner</label>
                            <input type="file" name="fileUpload" id="imgInput" class="form-control" accept="image/*" />
                        </div>

                        <!-- PREVIEW -->
                        <img id="preview"
                             src="@(Model != null && !string.IsNullOrEmpty(Model.HinhAnh)
                                ? Url.Content(Model.HinhAnh)
                                : "/AnhWeb/anhdan.png")"
                             class="banner-preview"
                             onerror="this.src='https://via.placeholder.com/400x200?text=No+Image'" />


                        <div class="mb-3">
                            <label class="form-label">Trạng thái</label>
                            <div class="form-check form-switch">
                                <input type="checkbox"
                                       name="TrangThai"
                                       value="true"
                                       class="form-check-input"
                                       style="width:50px;height:25px"
                                       checked />
                                <label class="form-check-label ms-2">Hiển thị</label>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Ngày bắt đầu</label>
                                @Html.TextBoxFor(m => m.NgayBatDau, new
                                {
                                    @class = "form-control",
                                    type = "date"
                                })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Ngày kết thúc</label>
                                @Html.TextBoxFor(m => m.NgayKetThuc, new
                                {
                                    @class = "form-control",
                                    type = "date"
                                })
                            </div>
                        </div>

                    </div>

                </div>

                <hr />

                <div class="text-end">
                    <a href="@Url.Action("QuanLyBanner")" class="btn btn-secondary me-2">
                        Hủy
                    </a>

                    <button type="submit" class="btn btn-success">
                        💾 Thêm banner
                    </button>
                </div>
            }

        </div>
    </div>
</div>

<script>
    document.getElementById("imgInput").addEventListener("change", function (e) {
        const file = e.target.files[0];
        if (file) {
            const url = URL.createObjectURL(file);
            document.getElementById("preview").src = url;
        }
    });
    </script>