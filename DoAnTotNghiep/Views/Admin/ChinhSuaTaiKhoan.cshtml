@model DoAnTotNghiep.Models.NguoiDung

@{
    ViewBag.Title = "Chỉnh sửa tài khoản";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #eef2f7;
        font-family: 'Segoe UI', sans-serif;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    .card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-header {
        background: linear-gradient(45deg, #4e73df, #224abe);
        color: white;
        border-radius: 18px 18px 0 0;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px;
    }

    .form-label {
        font-weight: 600;
    }

    .btn-primary {
        border-radius: 10px;
        padding: 10px 25px;
        background: #4e73df;
        border: none;
    }

    .btn-secondary {
        border-radius: 10px;
        padding: 10px 20px;
    }

    .info-box {
        background: #f8f9fc;
        padding: 10px;
        border-radius: 10px;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 15px;
        color: #4e73df;
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-user-edit"></i> Chỉnh sửa tài khoản</h2>

        <a href="@Url.Action("DanhSachTaiKhoan")" class="btn btn-secondary">
            ← Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            ✏️ Tài khoản #@Model.MaNguoiDung
        </div>

        <div class="card-body">

            @using (Html.BeginForm("ChinhSuaTaiKhoan", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaNguoiDung)

                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <div class="section-title">Thông tin cá nhân</div>

                        <div class="mb-3">
                            <label class="form-label">Họ và tên *</label>
                            @Html.TextBoxFor(m => m.Ten, new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email *</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Số điện thoại</label>
                            @Html.TextBoxFor(m => m.SoDienThoai, new { @class = "form-control" })
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="section-title">Thông tin hệ thống</div>

                        <div class="mb-3">
                            <label class="form-label">Vai trò *</label>
                            <select name="MaVaiTro" class="form-select">
                                <option value="">-- Chọn vai trò --</option>
                                @foreach (var item in (List<SelectListItem>)ViewBag.VaiTroList)
                                {
                                    <option value="@item.Value"
                                            @(Model.MaVaiTro.HasValue && Model.MaVaiTro.ToString() == item.Value ? "selected" : "")>
                                        @item.Text
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Địa chỉ</label>
                            @Html.TextAreaFor(m => m.DiaChi, new { @class = "form-control", rows = 3 })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ngày tạo</label>
                            <div class="info-box">
                                @(Model.NgayTao?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                            </div>
                        </div>

                    </div>

                </div>

                <hr />

                <!-- BUTTON -->
                <div class="text-end">
                    <a href="@Url.Action("DanhSachTaiKhoan")" class="btn btn-secondary me-2">
                        Hủy
                    </a>

                    <button type="submit" class="btn btn-primary">
                        💾 Cập nhật
                    </button>
                </div>
            }

        </div>
    </div>
</div>

<script>
    @if (TempData["Success"] != null)
    {
        <text>
            alert('@Html.Raw(TempData["Success"])');
        </text>
    }
</script>