@model DoAnTotNghiep.Models.Banner

@{
    ViewBag.Title = "Chỉnh sửa Banner";
    Layout = "~/Views/Shared/Admin.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #eef2f7;
        font-family: 'Segoe UI', sans-serif;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    .card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-header {
        background: linear-gradient(45deg, #f6c23e, #f4b619);
        color: white;
        border-radius: 18px 18px 0 0;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
    }

    .form-label {
        font-weight: 600;
    }

    .banner-preview {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px dashed #ddd;
    }

    .radio-group label {
        margin-right: 20px;
        font-weight: 500;
    }

    .btn {
        border-radius: 10px;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 15px;
        color: #f6c23e;
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-edit"></i> Chỉnh sửa Banner</h2>

        <a href="@Url.Action("QuanLyBanner")" class="btn btn-secondary">
            ← Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            🎯 Banner #@Model.MaBanner
        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            @using (Html.BeginForm("ChinhSuaBanner", "Admin", FormMethod.Post,
                new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaBanner)

                <div class="row">
                        <div class="section-title">Thông tin banner</div>

                        <div class="mb-3">
                            <label class="form-label">Tiêu đề</label>
                            @Html.TextBoxFor(m => m.TieuDe, new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Vị trí</label>
                            @Html.TextBoxFor(m => m.ViTri, new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Thứ tự</label>
                            @Html.TextBoxFor(m => m.ThuTu, new { @class = "form-control" })
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="section-title">Hình ảnh & trạng thái</div>

                        <div class="mb-3">
                            <label class="form-label">Ảnh banner</label>
                            <input type="file" name="fileUpload" id="imgInput" class="form-control" accept="image/*" />
                        </div>

                        <!-- PREVIEW -->
                        <img id="preview"
                             src="@(string.IsNullOrEmpty(Model.HinhAnh)
                                ? "/AnhWeb/anhdan.png"
                                : Url.Content(Model.HinhAnh))"
                             class="banner-preview"
                             onerror="this.src='https://via.placeholder.com/400x200?text=No+Image'" />

                        <!-- STATUS -->
                        <div class="mb-3 radio-group">
                            <label>Trạng thái</label><br />
                            <label>
                                @Html.RadioButtonFor(m => m.TrangThai, true) Hiển thị
                            </label>
                            <label>
                                @Html.RadioButtonFor(m => m.TrangThai, false) Ẩn
                            </label>
                        </div>

                        <!-- DATE -->
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Ngày bắt đầu</label>
                                @Html.TextBoxFor(m => m.NgayBatDau, "{0:yyyy-MM-dd}",
                                         new { @class = "form-control", type = "date" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Ngày kết thúc</label>
                                @Html.TextBoxFor(m => m.NgayKetThuc, "{0:yyyy-MM-dd}",
                                         new { @class = "form-control", type = "date" })
                            </div>
                        </div>

                    </div>

                <hr />

                <div class="text-end">
                    <a href="@Url.Action("QuanLyBanner")" class="btn btn-secondary me-2">
                        Hủy
                    </a>

                    <button type="submit" class="btn btn-primary">
                        💾 Lưu thay đổi
                    </button>
                </div>
            }

        </div>
    </div>
</div>

<script>
    document.getElementById("imgInput").addEventListener("change", function (e) {
        const file = e.target.files[0];
        if (file) {
            const url = URL.createObjectURL(file);
            document.getElementById("preview").src = url;
        }
    });
</script>