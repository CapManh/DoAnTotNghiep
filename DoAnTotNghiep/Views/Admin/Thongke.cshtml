@{
    ViewBag.Title = "Tổng Quan Hệ Thống - Quản Lý Nội Thất";
    Layout = "~/Views/Shared/Admin.cshtml";
}

<style>
    .dashboard-header {
        background: linear-gradient(135deg, #2c3e50, #3498db);
        color: white;
        padding: 30px 0;
        border-radius: 0 0 20px 20px;
        margin-bottom: 35px;
    }

    .kpi-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.09);
        transition: all 0.3s ease;
        height: 100%;
    }

        .kpi-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(52, 152, 219, 0.2);
        }

    .kpi-value {
        font-size: 2rem;
        font-weight: 700;
        color: #2c3e50;
    }

    .kpi-label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .section-title {
        font-weight: 700;
        color: #2c3e50;
        position: relative;
        padding-bottom: 12px;
    }

        .section-title:after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 50px;
            height: 4px;
            background: #3498db;
            border-radius: 4px;
        }

    .table thead {
        background-color: #3498db;
        color: white;
    }

    .highlight-row:hover {
        background-color: #f8fbff;
    }

    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.7rem;
    }
</style>

<div class="container-fluid px-4 py-3">

    <!-- Header -->
    <div class="dashboard-header text-center">
        <h1 class="fw-bold mb-2">Tổng Quan Hệ Thống</h1>
        <p class="lead mb-1 opacity-90">Cập nhật tình hình kinh doanh nội thất hôm nay</p>
        <small>@DateTime.Now.ToString("dd/MM/yyyy - HH:mm")</small>
    </div>

    <!-- KPI Cards -->
    <div class="row g-4">
        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">DOANH THU TỔNG</div>
                            <div class="kpi-value mt-2">@String.Format("{0:N0} ₫", ViewBag.DoanhThu)</div>
                        </div>
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">ĐƠN HÀNG</div>
                            <div class="kpi-value mt-2">@ViewBag.SoLuongDonHang</div>
                            <small class="text-muted">TB: @String.Format("{0:N0} ₫", ViewBag.AverageOrderValue)</small>
                        </div>
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="fas fa-shopping-bag"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">KHÁCH HÀNG</div>
                            <div class="kpi-value mt-2">@ViewBag.SoLuongKhachHang</div>
                            <small class="text-info">Mới tháng này: @ViewBag.KhachHangMoi</small>
                        </div>
                        <div class="icon-circle bg-info bg-opacity-10 text-info">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">SẢN PHẨM</div>
                            <div class="kpi-value mt-2">@ViewBag.SoLuongSanPham</div>
                            <small class="text-danger">Hết hàng: @ViewBag.SanPhamHetHang</small>
                        </div>
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="fas fa-box"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Các KPI bổ sung -->
        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">ĐƠN HÀNG HÔM NAY</div>
                            <div class="kpi-value mt-2">@ViewBag.DonHangHomNay</div>
                        </div>
                        <div class="icon-circle bg-danger bg-opacity-10 text-danger">
                            <i class="fas fa-calendar-day"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">GIÁ TRỊ TỒN KHO</div>
                            <div class="kpi-value mt-2">@String.Format("{0:N0} ₫", ViewBag.GiaTriTonKho)</div>
                        </div>
                        <div class="icon-circle bg-secondary bg-opacity-10 text-secondary">
                            <i class="fas fa-warehouse"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">ĐÁNH GIÁ TRUNG BÌNH</div>
                            <div class="kpi-value mt-2">@ViewBag.TrungBinhDanhGia ★</div>
                            <small>@ViewBag.TongDanhGia đánh giá</small>
                        </div>
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="fas fa-star"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="kpi-card card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="kpi-label">TỶ LỆ HOÀN THÀNH</div>
                            <div class="kpi-value mt-2">@ViewBag.TyLeHoanThanh %</div>
                        </div>
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="fas fa-check-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng dữ liệu -->
    <div class="row g-4 mt-5">
        <!-- Doanh Thu Theo Tháng -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-4">
                    <h5 class="section-title">Doanh Thu Theo Tháng</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Tháng/Năm</th>
                                    <th class="text-end">Doanh Thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (dynamic item in ViewBag.DoanhThuTheoThang)
                                {
                                    <tr class="highlight-row">
                                        <td class="fw-medium">@item.ThangNam</td>
                                        <td class="text-end fw-bold text-success">@String.Format("{0:N0} ₫", item.DoanhThu)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top 5 Sản Phẩm -->
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-4">
                    <h5 class="section-title">Top 5 Sản Phẩm Bán Chạy</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-end">Số lượng bán</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (dynamic item in ViewBag.TopSanPhamBanChay)
                                {
                                    <tr class="highlight-row">
                                        <td>@item.ProductName</td>
                                        <td class="text-end fw-bold">@item.Quantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-4">
        <!-- Top Khách Hàng -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-4">
                    <h5 class="section-title">Top 5 Khách Hàng Mua Nhiều Nhất</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Khách hàng</th>
                                    <th class="text-end">Số đơn hàng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (dynamic item in ViewBag.TopKhachHang)
                                {
                                    <tr class="highlight-row">
                                        <td>@item.FullName</td>
                                        <td class="text-end">@item.SoDonHang</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sản phẩm đánh giá thấp & Chưa bán -->
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-4">
                    <h5 class="section-title text-danger">Sản Phẩm Đánh Giá Thấp (1-2 sao)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-end">Số đánh giá thấp</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (dynamic item in ViewBag.SanPhamDanhGiaThap)
                                {
                                    <tr class="highlight-row">
                                        <td>@item.ProductName</td>
                                        <td class="text-end text-danger fw-bold">@item.SoDanhGiaThap</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white py-4">
                    <h5 class="section-title text-warning">Sản Phẩm Chưa Từng Bán</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.SanPhamChuaBan.Count > 0)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (dynamic item in ViewBag.SanPhamChuaBan)
                            {
                                <li class="list-group-item">@item.ProductName</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-success text-center py-4">Tất cả sản phẩm đều đã có đơn bán.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
}