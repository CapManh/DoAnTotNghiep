@model DoAnTotNghiep.Models.NguoiDung

@{
    ViewBag.Title = "Thêm tài khoản";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #eef2f7;
        font-family: 'Segoe UI', sans-serif;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    .card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-header {
        background: linear-gradient(45deg, #1cc88a, #17a673);
        color: white;
        border-radius: 18px 18px 0 0;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px;
    }

    .form-label {
        font-weight: 600;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 15px;
        color: #1cc88a;
    }

    .btn-success {
        border-radius: 10px;
        padding: 10px 30px;
    }

    .btn-secondary {
        border-radius: 10px;
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-user-plus"></i> Thêm tài khoản</h2>

        <a href="@Url.Action("DanhSachTaiKhoan")" class="btn btn-secondary">
            ← Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            ➕ Tạo tài khoản mới
        </div>

        <div class="card-body">

            @using (Html.BeginForm("ThemTaiKhoan", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <div class="section-title">Thông tin cá nhân</div>

                        <div class="mb-3">
                            <label class="form-label">Họ và tên *</label>
                            @Html.TextBoxFor(m => m.Ten, new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email *</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Số điện thoại</label>
                            @Html.TextBoxFor(m => m.SoDienThoai, new { @class = "form-control" })
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <div class="section-title">Thông tin tài khoản</div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu *</label>
                            <input type="password" name="MatKhau" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Vai trò *</label>
                            <select name="MaVaiTro" class="form-select">
                                <option value="">-- Chọn vai trò --</option>
                                @foreach (var item in (List<SelectListItem>)ViewBag.VaiTroList)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Địa chỉ</label>
                            @Html.TextAreaFor(m => m.DiaChi, new { @class = "form-control", rows = 3 })
                        </div>

                    </div>

                </div>

                <hr />

                <div class="text-end">
                    <a href="@Url.Action("DanhSachTaiKhoan")" class="btn btn-secondary me-2">
                        Hủy
                    </a>

                    <button type="submit" class="btn btn-success">
                        💾 Tạo tài khoản
                    </button>
                </div>
            }

        </div>
    </div>
</div>

<script>
    @if (TempData["Success"] != null)
    {
        <text>
            alert('@Html.Raw(TempData["Success"])');
        </text>
    }
</script>