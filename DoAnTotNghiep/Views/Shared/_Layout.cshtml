    <script src="~/Scripts/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSearch() {
            alert("✅ Tìm kiếm đã mở (bạn có thể thay bằng Bootstrap Modal sau)");
        }
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
        function toggleSearch() {
            const searchOverlay = document.getElementById('search-overlay');
            const isOpening = !searchOverlay.classList.contains('active');

            searchOverlay.classList.toggle('active');

            if (isOpening) {
                setTimeout(() => {
                    searchOverlay.querySelector('input').focus();
                }, 300);
            }
        }
        document.addEventListener('click', function (event) {
            const searchOverlay = document.getElementById('search-overlay');
            const searchBtn = document.querySelector('button[onclick="toggleSearch()"]');
            const isClickInside = searchOverlay.contains(event.target);
            const isClickButton = searchBtn.contains(event.target);
            if (!isClickInside && !isClickButton && searchOverlay.classList.contains('active')) {
                searchOverlay.classList.remove('active');
            }
        });
        document.addEventListener("DOMContentLoaded", function () {
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('#main-menu .nav-link');

            navLinks.forEach(link => {
                const linkPath = link.getAttribute('href');

                if (currentPath === linkPath || (currentPath === "/" && linkPath === "/")) {
                    link.classList.add('active');
                    link.classList.add('fw-bold');
                    link.style.color = "#000"; 
                } else {
                    link.classList.remove('active');
                    link.classList.remove('fw-bold');
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>