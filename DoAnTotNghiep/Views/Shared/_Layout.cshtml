                                    <i class="bi bi-person fs-4 text-muted"></i>
                                </span>
                                <input type="text" id="login-ten" class="form-control auth-input" placeholder="Nhập tên đăng nhập của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="small fw-bold text-muted mb-2">Mật khẩu</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-lock fs-4 text-muted"></i>
                                </span>
                                <input type="password" id="login-matkhau" class="form-control auth-input" placeholder="Nhập mật khẩu của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                                <span onclick="togglePassword('login-matkhau')" class="input-group-text bg-white border-start-0 rounded-end-3 cursor-pointer" style="border-color: #dadce0;">
                                    <i class="bi bi-eye toggle-password-icon"></i>
                                </span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mb-4">
                            <a href="#" class="small fw-semibold" style="color: #9b00ff; text-decoration: none;">Quên mật khẩu?</a>
                        </div>

                        <button onclick="attemptLogin()" class="btn w-100 py-3 text-white fw-semibold fs-5 rounded-3xl"
                                style="background: linear-gradient(to right, #00d4ff, #9b00ff); border: none; height: 56px;">
                            ĐĂNG NHẬP
                        </button>

                        <div class="d-flex align-items-center my-5">
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                            <span class="px-4 text-muted small fw-medium">Hoặc đăng ký bằng</span>
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                        </div>

