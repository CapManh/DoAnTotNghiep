
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Website Của Bạn</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/bootstrap-icons-1.2.2/bootstrap-icons-1.2.2/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/sweetalert2.all.min.js"></script>
    @RenderSection("PageCss", required: false)
</head>
<body>
    <div class="top-bar py-2">
        <div class="container d-flex justify-content-between align-items-center">
            <div class=-top-left d-flex align-items-center">
                <a href="#">Đánh Giá</a>
                <span class="sep-light mx-2">|</span>
                <a href="#">Hỗ Trợ</a>
            </div>

            <div class="top-right d-flex align-items-center gap-3">
                <a href="mailto:sales@matbao.ws"
                   class="d-flex align-items-center"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom"
                   title="ManhTuan@gmail.com">
                    <i class="bi bi-envelope me-1"></i>ManhTuan@gmail.com
                </a>

                <span class="sep-light">|</span>

                <a href="tel:02877777999"
                   class="d-flex align-items-center"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom"
                   title="(028) 7777 7999">
                    <i class="bi bi-phone me-1"></i>(028) 7777 7999
                </a>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg py-3">
        <div class="container d-flex align-items-center">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/AnhWeb/anhlogo.png" alt="Logo" class="logo-img" />
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <i class="bi bi-list fs-3"></i>
            </button>
            <span class="sep-dark mx-3">|</span>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto" id="main-menu">
                    <li class="nav-item"><a class="nav-link" href="/">Trang Chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/GioiThieu">Giới Thiệu</a></li>
                    @using DoAnTotNghiep.Models;

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle nav-product-link"
                           href="@Url.Action("sanpham1","Home")"
                           id="navbarDropdown"
                           role="button">

                            @(ViewBag.TenDanhMucDangChon ?? "Sản Phẩm")

                        </a>

                        <ul class="dropdown-menu border-0 custom-dropdown">

                            @if (ViewBag.DanhMucMenu != null)
                            {
                                foreach (var item in (List<DanhMuc>)ViewBag.DanhMucMenu)
                                {
                                    <li>
                                        <a class="dropdown-item"
                                           href="@Url.Action("sanpham1","Home",
                              new { danhMuc = item.MaDanhMuc })">

                                            @item.TenDanhMuc
                                        </a>
                                    </li>
                                }
                            }

                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/Home/LienHe">Liên Hệ</a></li>
                </ul>
            </div>

            <div class="right-actions d-flex align-items-center position-relative">
                <div id="default-actions" class="d-flex align-items-center gap-3">
                    @if (Session["MaNguoiDung"] != null)
                    {
                        <div class="dropdown d-inline-block">
                            <a href="#" class="action-item dropdown-toggle" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @Session["TenNguoiDung"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end p-3" aria-labelledby="userMenu" style="min-width: 280px; border-radius: 10px;">
                                <li class="mb-2 d-flex justify-content-between align-items-center">
                                    <h6 class="dropdown-header ps-0 text-dark fw-bold" style="font-size: 1.1rem;">Thông tin tài khoản</h6>
                                    <button class="btn btn-sm btn-outline-primary border-0" onclick="toggleEditMode(event)" id="btnEditProfile">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </li>

                                <li class="text-muted small mb-2">
                                    <i class="bi bi-person me-2"></i>Tên:
                                    <span class="view-mode">@Session["TenNguoiDung"]</span>
                                    <input type="text" class="form-control form-control-sm edit-mode d-none" id="inp-ten" value="@Session["TenNguoiDung"]">
                                    <div class="text-danger extra-small d-none" id="err-ten">Tên quá ngắn!</div>
                                </li>

                                <li class="text-muted small mb-2">
                                    <i class="bi bi-envelope me-2"></i>Email:
                                    <span class="view-mode">@(Session["Email"] ?? "Chưa cập nhật")</span>
                                    <input type="email" class="form-control form-control-sm edit-mode d-none" id="inp-email" value="@Session["Email"]">
                                    <div class="text-danger extra-small d-none" id="err-email">Email không hợp lệ!</div>
                                </li>

                                <li class="text-muted small mb-2">
                                    <i class="bi bi-telephone me-2"></i>SĐT:
                                    <span class="view-mode">@(Session["SDT"] ?? "Chưa cập nhật")</span>
                                    <input type="text" class="form-control form-control-sm edit-mode d-none" id="inp-sdt" value="@Session["SDT"]">
                                </li>

                                <li class="text-muted small mb-3">
                                    <i class="bi bi-geo-alt me-2"></i>Địa chỉ:
                                    <span class="view-mode">@(Session["DiaChi"] ?? "Chưa cập nhật")</span>
                                    <input type="text" class="form-control form-control-sm edit-mode d-none" id="inp-diachi" value="@Session["DiaChi"]">
                                </li>

                                <li class="edit-mode d-none mb-2">
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-primary btn-sm w-100" onclick="saveProfileChanges(event)">Lưu</button>
                                        <button class="btn btn-light btn-sm w-100" onclick="toggleEditMode(event)">Hủy</button>
                                    </div>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li class="view-mode"><a class="dropdown-item small" href="/Home/DonHangCuaToi"><i class="bi bi-bag-check me-2"></i>Đơn hàng</a></li>
                                <li class="pass-mode d-none px-2">
                                    <hr class="dropdown-divider">
                                    <h6 class="dropdown-header ps-0 text-dark fw-bold"><i class="bi bi-key me-2"></i>Đổi mật khẩu</h6>

                                    <div class="mb-2">
                                        <input type="password" id="inp-pass-old" class="form-control form-control-sm" placeholder="Mật khẩu hiện tại">
                                    </div>
                                    <div class="mb-2">
                                        <input type="password" id="inp-pass-new" class="form-control form-control-sm" placeholder="Mật khẩu mới">
                                    </div>
                                    <div class="mb-2">
                                        <input type="password" id="inp-pass-confirm" class="form-control form-control-sm" placeholder="Xác nhận mật khẩu mới">
                                    </div>

                                    <div class="d-flex gap-2 mt-2 mb-2">
                                        <button class="btn btn-warning btn-sm w-100 fw-bold" onclick="savePasswordChanges(event)">Cập nhật</button>
                                        <button class="btn btn-light btn-sm w-100" onclick="togglePassMode(event)">Hủy</button>
                                    </div>
                                </li>
                                <li class="view-mode">
                                    <a class="dropdown-item small" href="javascript:void(0)" onclick="togglePassMode(event)">
                                        <i class="bi bi-shield-lock me-2 text-warning"></i>Đổi mật khẩu
                                    </a>
                                </li>
                                <li class="view-mode"><a class="dropdown-item small text-danger" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="#" class="action-item" data-bs-toggle="modal" data-bs-target="#authModal">
                            <i class="bi bi-box-arrow-in-right"></i> Đăng Nhập
                        </a>
                    }
                    <span class="sep-dark">|</span>
                    <button onclick="toggleSearch()" class="btn d-flex align-items-center border-0 p-0 action-item">
                        <i class="bi bi-search me-1"></i>Tìm Kiếm
                    </button>
                    <span class="sep-dark">|</span>
                    <div class="action-item cart-wrapper position-relative">
                        <a href="/Home/GioHang" class="action-item d-flex align-items-center">
                            <i class="bi bi-bag"></i> Giỏ Hàng
                            <span class="badge rounded-pill bg-danger ms-1" id="cart-count">0</span>
                        </a>

                        <div class="mini-cart-dropdown shadow p-3">
                            <div id="cart-has-items" class="d-none">
                                <div id="mini-cart-list" style="max-height: 300px; overflow-y: auto; overflow-x: hidden;">
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted">Tổng tiền:</span>
                                    <span class="fw-bold text-danger" id="mini-cart-total">0 đ</span>
                                </div>
                                <div class="d-grid gap-2">
                                    <a href="/Home/GioHang" class="btn btn-outline-dark btn-sm">
                                        Xem Giỏ Hàng
                                    </a>
                                    <a href="/Home/ThanhToan"
                                       class="btn btn-warning btn-sm fw-bold">
                                        Thanh Toán
                                    </a>
                                </div>
                            </div>

                            <div id="cart-empty-content" class="text-center py-4">
                                <i class="bi bi-bag-x fs-1 text-muted"></i>
                                <p class="mt-2 text-muted">Giỏ hàng của Mạnh đang trống.</p>
                                <a href="/Home/sanpham1" class="btn btn-sm btn-primary">Mua sắm ngay</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="search-overlay" class="search-overlay-box">
                    <div class="d-flex align-items-center w-100 gap-2 position-relative">

                        <div class="search-line-dynamic"></div>
                        <i class="bi bi-search text-muted"></i>
                        <input type="text" id="searchBox" class="search-input-field" placeholder="Bạn tìm gì..." autocomplete="off">

                        <button onclick="toggleSearch()" class="btn-close-search">
                            <i class="bi bi-x-lg"></i>
                        </button>
                        <div id="suggestBox" class="list-group"></div>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    <div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
            <div class="modal-content border-0 shadow-2xl rounded-3xl overflow-hidden">

                <div class="modal-body p-5 pt-4">
                    <div id="login-content">
                        <h1 class="text-center fw-bold mb-1" style="font-size: 32px; letter-spacing: -1px;">Đăng nhập</h1>
                        <p class="text-center text-muted mb-5">để tiếp tục vào tài khoản</p>

                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Tên đăng nhập</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-person fs-4 text-muted"></i>
                                </span>
                                <input type="text" id="login-ten" class="form-control auth-input" placeholder="Nhập tên đăng nhập của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="small fw-bold text-muted mb-2">Mật khẩu</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-lock fs-4 text-muted"></i>
                                </span>
                                <input type="password" id="login-matkhau" class="form-control auth-input" placeholder="Nhập mật khẩu của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                                <span onclick="togglePassword('login-matkhau')" class="input-group-text bg-white border-start-0 rounded-end-3 cursor-pointer" style="border-color: #dadce0;">
                                    <i class="bi bi-eye toggle-password-icon"></i>
                                </span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mb-4">
                            <a href="#" class="small fw-semibold" style="color: #9b00ff; text-decoration: none;">Quên mật khẩu?</a>
                        </div>

                        <button onclick="attemptLogin()" class="btn w-100 py-3 text-white fw-semibold fs-5 rounded-3xl"
                                style="background: linear-gradient(to right, #00d4ff, #9b00ff); border: none; height: 56px;">
                            ĐĂNG NHẬP
                        </button>

                        <div class="d-flex align-items-center my-5">
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                            <span class="px-4 text-muted small fw-medium">Hoặc đăng ký bằng</span>
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                        </div>

                        <div class="text-center mt-5 small text-muted">
                            Chưa có tài khoản?
                            <a href="#" onclick="showRegisterContent()" class="fw-bold" style="color:#9b00ff;">Đăng ký ngay</a>
                        </div>
                    </div>
                    <div id="register-content" class="d-none">
                        <h1 class="text-center fw-bold mb-1" style="font-size: 32px; letter-spacing: -1px;">Đăng ký</h1>
                        <p class="text-center text-muted mb-5">Tham gia ngay để nhận ưu đãi</p>

                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Tên đăng nhập</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-person fs-4 text-muted"></i>
                                </span>
                                <input type="text" id="register-ten" class="form-control auth-input" placeholder="Nhập tên đăng nhập của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Email</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-envelope fs-4 text-muted"></i>
                                </span>
                                <input type="email" id="register-email" class="form-control auth-input" placeholder="Nhập email của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Số điện thoại</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-telephone fs-4 text-muted"></i>
                                </span>
                                <input type="text" id="register-sdt" class="form-control auth-input"
                                       placeholder="Nhập số điện thoại của bạn"
                                       style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Mật khẩu</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-lock fs-4 text-muted"></i>
                                </span>
                                <input type="password" id="register-matkhau" class="form-control auth-input" placeholder="Nhập mật khẩu của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                                <span onclick="togglePassword('register-matkhau')" class="input-group-text bg-white border-start-0 rounded-end-3 cursor-pointer" style="border-color: #dadce0;">
                                    <i class="bi bi-eye toggle-password-icon"></i>
                                </span>
                            </div>
                        </div>

                        <button onclick="attemptRegister()" class="btn w-100 py-3 text-white fw-semibold fs-5 rounded-3xl"
                                style="background: linear-gradient(to right, #00d4ff, #9b00ff); border: none; height: 56px;">
                            ĐĂNG KÝ
                        </button>

                        <div class="d-flex align-items-center my-5">
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                            <span class="px-4 text-muted small fw-medium">Hoặc đăng nhập bằng</span>
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                        </div>

                        <div class="text-center mt-5 small text-muted">
                            Đã có tài khoản?
                            <a href="#" onclick="showLoginContent()" class="fw-bold" style="color:#9b00ff;">Đăng nhập</a>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-close position-absolute top-4 end-4" data-bs-dismiss="modal" aria-label="Close" style="z-index:10;"></button>
            </div>
        </div>
    </div>
    <main class="container">
        @RenderBody()
    </main>
