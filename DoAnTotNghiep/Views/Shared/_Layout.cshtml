    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSearch() {
            const searchOverlay = document.getElementById('search-overlay');
            const suggestBox = document.getElementById('suggestBox');

            const isOpening = !searchOverlay.classList.contains('active');

            searchOverlay.classList.toggle('active');

            if (isOpening) {
                setTimeout(() => {
                    document.getElementById('searchBox').focus();
                }, 300);
            } else {
                suggestBox.style.display = "none";
            }
        }
        document.addEventListener('click', function (event) {
            const searchOverlay = document.getElementById('search-overlay');
            const searchBtn = document.querySelector('button[onclick="toggleSearch()"]');
            const isClickInside = searchOverlay.contains(event.target);
            const isClickButton = searchBtn.contains(event.target);
            if (!isClickInside && !isClickButton && searchOverlay.classList.contains('active')) {
                searchOverlay.classList.remove('active');
            }
        });
        document.addEventListener("DOMContentLoaded", function () {
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('#main-menu .nav-link');

            navLinks.forEach(link => {
                const linkPath = link.getAttribute('href');

                if (currentPath === linkPath || (currentPath === "/" && linkPath === "/")) {
                    link.classList.add('active');
                    link.classList.add('fw-bold');
                    link.style.color = "#000";
                } else {
                    link.classList.remove('active');
                    link.classList.remove('fw-bold');
                }
            });
        });
        function attemptLogin() {
            var loginData = {
                Ten: $('#login-ten').val()?.trim() || '',
                MatKhau: $('#login-matkhau').val()?.trim() || ''
            };

            if (!loginData.Ten || !loginData.MatKhau) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Thông báo',
                    text: 'Vui lòng nhập đầy đủ Tên và Mật khẩu nhé!',
                    confirmButtonColor: '#9b00ff'
                });
                return;
            }

            Swal.fire({
                title: 'Đang xác thực...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            $.ajax({
                url: '@Url.Action("Login", "Home")',
                type: 'POST',
                data: loginData,

                success: function (response) {

                    Swal.close();

                    if (response.success) {

                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 1500,
                            timerProgressBar: true
                        });

                        Toast.fire({
                            icon: 'success',
                            title: response.message
                        });
                        setTimeout(function () {
                            window.location.href = response.redirect;
                        }, 1500);

                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Đăng nhập thất bại',
                            text: response.message,
                            confirmButtonColor: '#9b00ff'
                        });
                    }
                },

                error: function (xhr) {
                    Swal.close();

                    console.error(xhr.responseText);

                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi hệ thống',
                        text: 'Không thể kết nối đến máy chủ'
                    });
                }
            });
        }
        function attemptRegister() {
            var userData = {
                Ten: $('#register-ten').val().trim(),
                Email: $('#register-email').val().trim(),
                MatKhau: $('#register-matkhau').val().trim(),
                SoDienThoai: $('#register-sdt').val().trim()
            };
            if (!userData.Ten || !userData.Email || !userData.MatKhau || !userData.SoDienThoai) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Thiếu thông tin',
                    text: 'Vui lòng điền đầy đủ các trường dữ liệu!',
                    confirmButtonColor: '#9b00ff'
                });
                return;
            }
            Swal.fire({
                title: 'Đang xử lý...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });
            $.ajax({
                url: '@Url.Action("Register", "Home")',
                type: 'POST',
                data: userData,
                success: function (response) {
                    Swal.close();

                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Đăng ký thành công!',
                            text: response.message,
                            confirmButtonColor: '#00d4ff'
                        }).then(() => {
                            showLoginContent();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi đăng ký',
                            text: response.message,
                            confirmButtonColor: '#ea4335'
                        });
                    }
                },
                error: function (xhr) {
                    Swal.close();
                    console.error(xhr.responseText);
                    Swal.fire('Lỗi', 'Mã lỗi: ' + xhr.status + '. Kiểm tra Controller!', 'error');
                }
            });
        }
        function showRegisterContent() {
            document.getElementById('login-content').classList.add('d-none');
            document.getElementById('register-content').classList.remove('d-none');
        }
        function showLoginContent() {
            document.getElementById('register-content').classList.add('d-none');
            document.getElementById('login-content').classList.remove('d-none');
        }
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = input.parentElement.querySelector('.toggle-password-icon');

            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
        function handlePromoRegister() {
            var emailValue = $('#promo-email-input').val().trim();

            if (emailValue === "") {
                Swal.fire('Thông báo', 'Vui lòng nhập email để nhận ưu đãi!', 'info');
                return;
            }
            $('#register-email').val(emailValue);
            var authModal = new bootstrap.Modal(document.getElementById('authModal'));
            authModal.show();
            showRegisterContent();
        }
        function toggleEditMode(e) {
            if (e) e.stopPropagation();
            $('.view-mode').toggleClass('d-none');
            $('.edit-mode').toggleClass('d-none');
        }
        function saveProfileChanges(e) {
            if (e) e.stopPropagation();

            var updateData = {
                Ten: $('#inp-ten').val().trim(),
                Email: $('#inp-email').val().trim(),
                SoDienThoai: $('#inp-sdt').val().trim(),
                DiaChi: $('#inp-diachi').val().trim()
            };
            if (updateData.Ten.length < 5) {
                Swal.fire('Thông báo', 'Tên đăng nhập phải có ít nhất 5 ký tự!', 'warning');
                return;
            }
            var emailPattern = "^[^\\s\\u0040]+\\u0040[^\\s\\u0040]+\\.[^\\s\\u0040]+$";
            var emailRegex = new RegExp(emailPattern);
            if (!emailRegex.test(updateData.Email)) {
                Swal.fire('Thông báo', 'Email không đúng định dạng!', 'warning');
                return;
            }
            if (updateData.SoDienThoai === "") {
                Swal.fire('Thông báo', 'bạn chưa nhập Số điện thoại kìa!', 'warning');
                return;
            }
            var sdtRegex = /^[0-9]{10,11}$/;
            if (!sdtRegex.test(updateData.SoDienThoai)) {
                Swal.fire('Thông báo', 'Số điện thoại phải là chữ số và có độ dài 10-11 số!', 'warning');
                return;
            }
            if (updateData.DiaChi === "") {
                Swal.fire('Thông báo', 'Vui lòng nhập địa chỉ để chúng mình giao hàng nhé!', 'warning');
                return;
            }
            $.ajax({
                url: '@Url.Action("UpdateProfile", "Home")',
                type: 'POST',
                data: updateData,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            timer: 1000,
                            showConfirmButton: false
                        }).then(() => { location.reload(); });
                    } else {
                        Swal.fire('Thất bại', res.message, 'error');
                    }
                },
                error: function (xhr) {
                    Swal.fire('Lỗi', 'Không thể lưu. Nhấn F12 xem chi tiết lỗi server!', 'error');
                }
            });
        }
        function togglePassMode(e) {
            if (e) e.stopPropagation();
            $('.view-mode').toggleClass('d-none');
            $('.pass-mode').toggleClass('d-none');
            $('#inp-pass-old, #inp-pass-new, #inp-pass-confirm').val('');
        }
        function savePasswordChanges(e) {
            if (e) e.stopPropagation();

            var passOld = $('#inp-pass-old').val().trim();
            var passNew = $('#inp-pass-new').val().trim();
            var passConf = $('#inp-pass-confirm').val().trim();
            if (!passOld || !passNew || !passConf) {
                Swal.fire('Thông báo', 'Vui lòng nhập đầy đủ 3 ô mật khẩu!', 'warning');
                return;
            }
            if (passNew.length < 6) {
                Swal.fire('Thông báo', 'Mật khẩu mới phải có ít nhất 6 ký tự!', 'warning');
                return;
            }
            if (passNew !== passConf) {
                Swal.fire('Lỗi', 'Xác nhận mật khẩu mới không khớp!', 'error');
                return;
            }
            $.ajax({
                url: '@Url.Action("UpdatePassword", "Home")',
                type: 'POST',
                data: {
                    OldPass: passOld,
                    NewPass: passNew
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire('Thành công', 'Mật khẩu đã được thay đổi!', 'success')
                            .then(() => { location.reload(); });
                    } else {
                        Swal.fire('Thất bại', res.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Không thể kết nối đến hệ thống!', 'error');
                }
            });
        }
        $(function () {
            $(document)
                .off('click', '.add-cart')
                .on('click', '.add-cart', function (e) {

                    e.preventDefault();

                    let spId = $(this).data('id');

                    $.ajax({
                        url: '@Url.Action("ThemGioHang","Home")',
                        type: 'POST',
                        data: { id: spId },

                        success: function (res) {

                            if (!res.success) {
                                Swal.fire('Thông báo', res.message, 'warning');
                                return;
                            }

                            $('#cart-count').text(res.totalQuantity);

                            renderMiniCart(res.cartItems, res.totalAmount);

                            $('.mini-cart-dropdown').stop(true,true).fadeIn(200);

                            Swal.fire({
                                icon: 'success',
                                title: 'Đã thêm vào giỏ',
                                timer: 1200,
                                showConfirmButton: false
                            });
                        }
                    });

                });
            $(document)
                .off('click', '.btn-remove-cart')
                .on('click', '.btn-remove-cart', function () {

                    let id = $(this).data('id');

                    $.post('/Home/XoaGioHang', { id: id }, function (res) {

                        if (res.success) {
                            $('#cart-count').text(res.totalQuantity);
                            renderMiniCart(res.cartItems, res.totalAmount);
                        }
                    });
                });
            $('.cart-wrapper')
                .off('mouseenter mouseleave')
                .hover(
                    function () {
                        $('.mini-cart-dropdown').stop(true,true).fadeIn(200);
                    },
                    function () {
                        $('.mini-cart-dropdown').stop(true,true).fadeOut(200);
                    }
                );
            loadMiniCart();

        });
        function renderMiniCart(items, total) {

            const list = $('#mini-cart-list');
            list.empty();

            let coLoiTonKho = false;

            if (items && items.length > 0) {

                $('#cart-has-items').removeClass('d-none');
                $('#cart-empty-content').addClass('d-none');

                items.forEach(item => {

                    let ten = item.TenSP;
                    let gia = item.Gia || 0;
                    let anh = item.AnhChinh || "/AnhWeb/default-product.png";
                    let sl = item.SL || 0;
                    let tonKho = item.TonKho || 0;
                    let link = item.Link || "/Home/chitietsanpham/" + item.MaSP;

                    let canhBao = "";

                    if (sl > tonKho) {
                        canhBao = `
                <div class="text-danger small">
                    Chỉ còn ${tonKho} sản phẩm trong kho
                </div>`;

                        coLoiTonKho = true;
                    }

                    let html = `
            <div class="d-flex align-items-start mb-3 position-relative">

                <a href="${link}">
                    <img src="${anh}"
                         class="rounded border"
                         style="width:55px;height:55px;object-fit:cover;">
                </a>

                <div class="ms-3 flex-grow-1">

                    <a href="${link}"
                       class="fw-bold small text-dark text-decoration-none cart-name">
                       ${ten}
                    </a>

                    <div class="text-danger fw-bold">
                        ${gia.toLocaleString()} đ
                    </div>

                    <div class="small text-muted">
                        SL: ${sl}
                    </div>

                    ${canhBao}

                    <button class="btn-remove-cart"
                        data-id="${item.MaSP}"
                        style="border:none;background:none;font-size:18px;color:#999;">
                    ×
                </button>

                </div>

            </div>`;

                    list.append(html);
                });

                $('#mini-cart-total')
                    .text(total.toLocaleString() + ' đ');
                if (coLoiTonKho) {

                    $('#btn-checkout-mini')
                        .prop('disabled', true)
                        .text('Số lượng vượt tồn kho');

                } else {

                    $('#btn-checkout-mini')
                        .prop('disabled', false)
                        .text('Thanh toán');
                }

            } else {

                $('#cart-has-items').addClass('d-none');
                $('#cart-empty-content').removeClass('d-none');
            }
        }
        function loadMiniCart() {
            $.get('/Home/LayGioHang', function (res) {
                if (res.success) {
                    $('#cart-count').text(res.totalQuantity);
                    renderMiniCart(res.cartItems, res.totalAmount);
                }
            });
        }

        let timeout = null;

        document.getElementById("searchBox").addEventListener("keyup", function () {
            clearTimeout(timeout);

            let keyword = this.value;

            timeout = setTimeout(() => {

                if (keyword.trim() === "") {
                    document.getElementById("suggestBox").style.display = "none";
                    return;
                }

                fetch(`/SanPham/Suggest?keyword=${encodeURIComponent(keyword)}`)
                    .then(res => res.json())
                    .then(data => {

                        let html = "";

                        if (data.length === 0) {
                            html = `<div class="list-group-item text-muted">Không có sản phẩm</div>`;
                        } else {
                            data.forEach(item => {
                                html += `
                            <a href="/SanPham/Detail/${item.MaSanPham}"
                               class="list-group-item list-group-item-action">

                                <img src="${item.AnhChinh}" />
                                <span>${item.TenSanPham}</span>
                            </a>
                        `;
                            });
                        }

                        const box = document.getElementById("suggestBox");
                        box.innerHTML = html;
                        box.style.display = "block";
                    });

            }, 300);
        });
        document.getElementById("searchBox").addEventListener("keypress", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();

                let keyword = this.value.trim();

                if (keyword !== "") {
                    window.location.href = "/Home/sanpham1?keyword=" + encodeURIComponent(keyword);
                }
            }
        });
        $('.mini-checkout').on('click', function () {

            document.querySelectorAll('.item-checkbox')
                .forEach(cb => cb.checked = true);

            processCheckout();
        });
        function processCheckout() {

            const selected =
                document.querySelectorAll('.item-checkbox:checked');

            if (selected.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Chưa chọn sản phẩm',
                    text: 'Vui lòng chọn ít nhất một sản phẩm để thanh toán!',
                    confirmButtonColor: '#ff4d4f'
                });
                return;
            }

            Swal.fire({
                title: 'Đang chuyển đến trang thanh toán...',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => Swal.showLoading()
            });

            setTimeout(() => {

                const ids = Array.from(selected)
                    .map(cb => cb.value)
                    .join(',');

                window.location.href =
                    '/Home/ThanhToan?ids=' + encodeURIComponent(ids);

            }, 500);
        }

    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>