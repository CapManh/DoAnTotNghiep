                            Chưa có tài khoản?
                            <a href="#" onclick="showRegisterContent()" class="fw-bold" style="color:#9b00ff;">Đăng ký ngay</a>
                        </div>
                    </div>

                    <!-- FORM ĐĂNG KÝ -->
                    <div id="register-content" class="d-none">
                        <h1 class="text-center fw-bold mb-1" style="font-size: 32px; letter-spacing: -1px;">Đăng ký</h1>
                        <p class="text-center text-muted mb-5">Tham gia ngay để nhận ưu đãi</p>

                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Tên đăng nhập</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-person fs-4 text-muted"></i>
                                </span>
                                <input type="text" id="register-ten" class="form-control auth-input" placeholder="Nhập tên đăng nhập của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Email</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-envelope fs-4 text-muted"></i>
                                </span>
                                <input type="email" id="register-email" class="form-control auth-input" placeholder="Nhập email của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="small fw-bold text-muted mb-2">Mật khẩu</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3" style="border-color: #dadce0;">
                                    <i class="bi bi-lock fs-4 text-muted"></i>
                                </span>
                                <input type="password" id="register-matkhau" class="form-control auth-input" placeholder="Nhập mật khẩu của bạn" style="border-left: none; border-radius: 0 12px 12px 0;">
                                <span onclick="togglePassword('register-matkhau')" class="input-group-text bg-white border-start-0 rounded-end-3 cursor-pointer" style="border-color: #dadce0;">
                                    <i class="bi bi-eye toggle-password-icon"></i>
                                </span>
                            </div>
                        </div>

                        <button onclick="attemptRegister()" class="btn w-100 py-3 text-white fw-semibold fs-5 rounded-3xl"
                                style="background: linear-gradient(to right, #00d4ff, #9b00ff); border: none; height: 56px;">
                            ĐĂNG KÝ
                        </button>

                        <div class="d-flex align-items-center my-5">
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                            <span class="px-4 text-muted small fw-medium">Hoặc đăng nhập bằng</span>
                            <hr class="flex-grow-1" style="border-color: #dadce0;">
                        </div>

                        <div class="d-flex justify-content-center gap-4">
                            <button onclick="socialLogin('facebook')" class="btn rounded-3xl d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:#1877f2;border:none;color:white;"><i class="bi bi-facebook fs-3"></i></button>
                            <button onclick="socialLogin('twitter')" class="btn rounded-3xl d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:#1da1f2;border:none;color:white;"><i class="bi bi-twitter fs-3"></i></button>
                            <button onclick="socialLogin('google')" class="btn rounded-3xl d-flex align-items-center justify-content-center text-white fw-bold fs-3" style="width:56px;height:56px;background:#ea4335;border:none;">G</button>
                        </div>

                        <div class="text-center mt-5 small text-muted">
                            Đã có tài khoản?
                            <a href="#" onclick="showLoginContent()" class="fw-bold" style="color:#9b00ff;">Đăng nhập</a>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-close position-absolute top-4 end-4" data-bs-dismiss="modal" aria-label="Close" style="z-index:10;"></button>
            </div>
        </div>
    </div>
